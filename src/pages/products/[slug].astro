---
import Layout from '@/layouts/Layout.astro';
import productsData from '@/data/products.json';

// Generate static paths for all products
export async function getStaticPaths() {
  return productsData.map((product) => ({
    params: { slug: product.id },
    props: { product }
  }));
}

const { product } = Astro.props;

// Related products - intelligent selection
let relatedProducts = productsData
  .filter(p => p.category === product.category && p.id !== product.id)
  .slice(0, 3);

// If not enough products in same category, fill with other categories
if (relatedProducts.length < 2) {
  const otherProducts = productsData
    .filter(p => p.category !== product.category && p.id !== product.id)
    .slice(0, 3 - relatedProducts.length);
  relatedProducts = [...relatedProducts, ...otherProducts];
}

// Only show if we have at least 2 products
const shouldShowRelated = relatedProducts.length >= 2;

// Ensure we have a fallback title
const relatedTitle = relatedProducts.filter(p => p.category === product.category).length > 0 
  ? "Benzer" 
  : relatedProducts.length > 0 
    ? "Diğer" 
    : "Önerilen";

// Get category display name
function getCategoryName(category) {
  const categoryNames = {
    'drill': 'Akülü Darbeli Matkap',
    'driver': product.subcategory || 'Akülü Vidalama',
    'grinder': 'Akülü Taşlama',
    'hammer': 'Akülü Kırıcı Delici',
    'battery': product.subcategory || 'Batarya',
    'charger': product.subcategory || 'Şarj Cihazı',
    'storage': 'Taşıma Kutusu Sistemi'
  };
  return categoryNames[category] || product.subcategory || category;
}
---

<Layout 
  title={`${product.title} - ${getCategoryName(product.category)} | Voltz Power Tools`}
  description={`${product.title} ${getCategoryName(product.category)} özellikleri ve fiyatı. ${product.description} Brushless motor teknolojisi, V-PACK uyumlu batarya sistemi.`}
  keywords={`${product.title}, ${getCategoryName(product.category)}, voltz ${product.category}, ${product.voltage} alet, brushless motor, v-pack uyumlu`}
>

<!-- Breadcrumb -->
<section class="pd-breadcrumb-section">
  <div class="pd-container">
    <nav class="pd-breadcrumb" aria-label="Breadcrumb">
      <a href="/" class="pd-breadcrumb-link">Anasayfa</a>
      <span class="pd-breadcrumb-sep">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </span>
      <a href="/products" class="pd-breadcrumb-link">Ürünler</a>
      <span class="pd-breadcrumb-sep">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </span>
      <span class="pd-breadcrumb-current">{product.title}</span>
    </nav>
  </div>
</section>

<!-- Product Hero: Two-Column Layout -->
<section class="pd-hero">
  <div class="pd-container">
    <div class="pd-hero-grid">

      <!-- LEFT: Image Gallery -->
      <div class="pd-gallery">
        <div class="pd-gallery-main" id="pdGalleryMain">
          <img 
            src={product.images[0]} 
            alt={product.title} 
            class="pd-gallery-main-img" 
            id="pdMainImage"
            data-hd-src={product.imagesHd[0]}
          />
          {product.voltage && product.voltage !== 'N/A' && product.category !== 'storage' && (
            <div class="pd-voltage-badge">
              <span class="pd-voltage-num">{product.voltage.replace('VDC', 'V')}</span>
              <span class="pd-voltage-label">V-PACK</span>
            </div>
          )}
          <button class="pd-zoom-btn" id="pdZoomBtn" aria-label="Büyüt">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>
          </button>
        </div>
        <div class="pd-gallery-thumbs" id="pdThumbs">
          {product.images.map((imgUrl, idx) => (
            <button 
              class={`pd-thumb ${idx === 0 ? 'active' : ''}`} 
              data-image={imgUrl} 
              data-hd={product.imagesHd[idx]}
              data-index={idx}
              aria-label={`Görsel ${idx + 1}`}
            >
              <img src={imgUrl} alt={`${product.title} - Görsel ${idx + 1}`} />
            </button>
          ))}
        </div>
      </div>

      <!-- RIGHT: Product Info -->
      <div class="pd-info">
        <div class="pd-badges">
          {product.category !== 'battery' && product.category !== 'charger' && product.category !== 'storage' && (
            <span class="pd-badge pd-badge-green">BRUSHLESS</span>
          )}
          {(product.category === 'drill' || product.category === 'driver' || product.category === 'hammer' || product.category === 'grinder') && (
            <span class="pd-badge pd-badge-dark">HEAVY DUTY</span>
          )}
          {product.voltage && product.voltage !== 'N/A' && (
            <span class="pd-badge pd-badge-outline">{product.voltage}</span>
          )}
        </div>

        <h1 class="pd-title">{product.title}</h1>
        <p class="pd-category">{getCategoryName(product.category)}</p>
        <p class="pd-description">{product.description}</p>

        <!-- Key Specs Grid -->
        <div class="pd-key-specs">
          {product.voltage && product.voltage !== 'N/A' && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">Voltaj</span>
              <span class="pd-key-spec-value">{product.voltage}</span>
            </div>
          )}
          {product.torque && product.torque !== 'N/A' && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">Tork</span>
              <span class="pd-key-spec-value">{product.torque}</span>
            </div>
          )}
          {product.speed && product.speed !== 'N/A' && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">Hız</span>
              <span class="pd-key-spec-value">{product.speed}</span>
            </div>
          )}
          {product.weight && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">Ağırlık</span>
              <span class="pd-key-spec-value">{product.weight}</span>
            </div>
          )}
          {product.chuck && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">{product.category === 'drill' ? 'Mandren' : 'Bağlantı'}</span>
              <span class="pd-key-spec-value">{product.chuck}</span>
            </div>
          )}
          {product.bpm && product.bpm !== 'N/A' && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">Darbe</span>
              <span class="pd-key-spec-value">{product.bpm}</span>
            </div>
          )}
          {product.diskSize && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">Disk Çapı</span>
              <span class="pd-key-spec-value">{product.diskSize}</span>
            </div>
          )}
          {product.capacity && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">Kapasite</span>
              <span class="pd-key-spec-value">{product.capacity}</span>
            </div>
          )}
          {product.energy && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">Enerji</span>
              <span class="pd-key-spec-value">{product.energy}</span>
            </div>
          )}
          {product.current && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">Çıkış</span>
              <span class="pd-key-spec-value">{product.current}</span>
            </div>
          )}
        </div>

        <!-- Features Checklist -->
        {product.features && product.features.length > 0 && (
          <div class="pd-features">
            <h3 class="pd-features-title">Özellikler</h3>
            <ul class="pd-features-list">
              {product.features.map((feature) => (
                <li class="pd-feature-item">
                  <svg class="pd-check-icon" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--green, #6BE03F)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<!-- Package Contents -->
<section class="pd-package-section">
  <div class="pd-container">

    {product.batteryIncluded && product.category !== 'storage' && product.category !== 'battery' && product.category !== 'charger' && (
      <div class="pd-package-card">
        <div class="pd-package-header">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--green, #6BE03F)" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          <h3>Paket İçeriği</h3>
        </div>
        <div class="pd-package-grid">
          <div class="pd-package-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--green, #6BE03F)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>1x {product.title}</span>
          </div>
          <div class="pd-package-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--green, #6BE03F)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>2x {product.voltage} Batarya</span>
          </div>
          <div class="pd-package-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--green, #6BE03F)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>1x Hızlı Şarj Cihazı</span>
          </div>
          <div class="pd-package-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--green, #6BE03F)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Kullanım Kılavuzu</span>
          </div>
          <div class="pd-package-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--green, #6BE03F)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Garanti Belgesi</span>
          </div>
        </div>
        <div class="pd-package-vpack">
          <span class="pd-vpack-tag">V-PACK</span> Uyumlu Sistem
        </div>
      </div>
    )}

    {product.category === 'battery' && (
      <div class="pd-package-card">
        <div class="pd-package-header">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--green, #6BE03F)" stroke-width="2"><rect x="1" y="6" width="18" height="12" rx="2" ry="2"/><line x1="23" y1="13" x2="23" y2="11"/></svg>
          <h3>Batarya Özellikleri</h3>
        </div>
        <div class="pd-battery-specs">
          <div class="pd-battery-stat">
            <span class="pd-battery-stat-value">{product.voltage}</span>
            <span class="pd-battery-stat-label">Voltaj</span>
          </div>
          {product.capacity && (
            <div class="pd-battery-stat">
              <span class="pd-battery-stat-value">{product.capacity}</span>
              <span class="pd-battery-stat-label">Kapasite</span>
            </div>
          )}
          {product.energy && (
            <div class="pd-battery-stat">
              <span class="pd-battery-stat-value">{product.energy}</span>
              <span class="pd-battery-stat-label">Enerji</span>
            </div>
          )}
        </div>
      </div>
    )}

    {product.category === 'charger' && (
      <div class="pd-package-card">
        <div class="pd-package-header">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--green, #6BE03F)" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          <h3>Şarj Cihazı Özellikleri</h3>
        </div>
        <div class="pd-battery-specs">
          {product.voltage && (
            <div class="pd-battery-stat">
              <span class="pd-battery-stat-value">{product.voltage}</span>
              <span class="pd-battery-stat-label">Voltaj</span>
            </div>
          )}
          {product.current && (
            <div class="pd-battery-stat">
              <span class="pd-battery-stat-value">{product.current}</span>
              <span class="pd-battery-stat-label">Çıkış</span>
            </div>
          )}
        </div>
      </div>
    )}

    {product.category === 'storage' && (
      <div class="pd-package-card">
        <div class="pd-package-header">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--green, #6BE03F)" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          <h3>Sistem Özellikleri</h3>
        </div>
        <div class="pd-storage-features">
          <div class="pd-storage-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--green, #6BE03F)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Modüler İstiflenebilir</span>
          </div>
          <div class="pd-storage-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--green, #6BE03F)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Güvenli Kilit Sistemi</span>
          </div>
          <div class="pd-storage-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--green, #6BE03F)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Ergonomik Taşıma</span>
          </div>
        </div>
      </div>
    )}

  </div>
</section>

<!-- Technical Specifications Table -->
<section class="pd-specs-section">
  <div class="pd-container">
    <h2 class="pd-section-title">Teknik <span class="pd-highlight">Özellikler</span></h2>
    <div class="pd-specs-table">
      <div class="pd-spec-row">
        <span class="pd-spec-label">Model</span>
        <span class="pd-spec-value">{product.id.toUpperCase()}</span>
      </div>

      {product.chuck && (
        <div class="pd-spec-row">
          <span class="pd-spec-label">{product.category === 'drill' ? 'Metal Mandren' : 'Bağlantı Çıkışı'}</span>
          <span class="pd-spec-value">{product.chuck}</span>
        </div>
      )}

      {product.torque && product.torque !== 'N/A' && (
        <div class="pd-spec-row">
          <span class="pd-spec-label">{product.category === 'drill' ? 'Maximum Tork' : 'İleri Tork'}</span>
          <span class="pd-spec-value">{product.torque}</span>
        </div>
      )}

      {product.speed && product.speed !== 'N/A' && (
        <div class="pd-spec-row">
          <span class="pd-spec-label">Yüksüz Hız</span>
          <span class="pd-spec-value">{product.speed}</span>
        </div>
      )}

      {product.bpm && product.bpm !== 'N/A' && (
        <div class="pd-spec-row">
          <span class="pd-spec-label">Darbe Frekansı</span>
          <span class="pd-spec-value">{product.bpm}</span>
        </div>
      )}

      {product.diskSize && (
        <div class="pd-spec-row">
          <span class="pd-spec-label">Disk Çapı</span>
          <span class="pd-spec-value">{product.diskSize}</span>
        </div>
      )}

      {product.cuttingDepth && (
        <div class="pd-spec-row">
          <span class="pd-spec-label">Maximum Kesme Derinliği</span>
          <span class="pd-spec-value">{product.cuttingDepth}</span>
        </div>
      )}

      {product.drillDiameter && (
        <div class="pd-spec-row">
          <span class="pd-spec-label">Delme Çapı</span>
          <span class="pd-spec-value">{product.drillDiameter}</span>
        </div>
      )}

      {product.impactEnergy && (
        <div class="pd-spec-row">
          <span class="pd-spec-label">Darbe Enerjisi</span>
          <span class="pd-spec-value">{product.impactEnergy}</span>
        </div>
      )}

      {product.capacity && (
        <div class="pd-spec-row">
          <span class="pd-spec-label">Kapasite</span>
          <span class="pd-spec-value">{product.capacity}</span>
        </div>
      )}

      {product.energy && (
        <div class="pd-spec-row">
          <span class="pd-spec-label">Enerji</span>
          <span class="pd-spec-value">{product.energy}</span>
        </div>
      )}

      {product.current && (
        <div class="pd-spec-row">
          <span class="pd-spec-label">Çıkış</span>
          <span class="pd-spec-value">{product.current}</span>
        </div>
      )}

      {product.dimensions && (
        <div class="pd-spec-row">
          <span class="pd-spec-label">Boyutlar</span>
          <span class="pd-spec-value">{product.dimensions}</span>
        </div>
      )}

      {product.weight && (
        <div class="pd-spec-row">
          <span class="pd-spec-label">Ağırlık</span>
          <span class="pd-spec-value">{product.weight}</span>
        </div>
      )}
    </div>
  </div>
</section>

<!-- Related Products -->
{shouldShowRelated && (
  <section class="pd-related-section">
    <div class="pd-container">
      <h2 class="pd-section-title">{relatedTitle} <span class="pd-highlight">Ürünler</span></h2>
      <div class={`pd-related-grid ${relatedProducts.length === 2 ? 'pd-related-two' : ''}`}>
        {relatedProducts.map((rp) => (
          <a href={`/products/${rp.id}`} class="pd-related-card">
            <div class="pd-related-img-wrap">
              <img src={rp.images?.[0] || rp.image} alt={rp.title} class="pd-related-img" />
              {rp.voltage && rp.voltage !== 'N/A' && rp.category !== 'storage' && (
                <div class="pd-related-voltage">
                  <img 
                    src={rp.voltage && rp.voltage.includes("20") ? "/icons/20pack-icon.svg" : "/icons/16.8pack-icon.svg"} 
                    alt={rp.voltage}
                  />
                </div>
              )}
            </div>
            <div class="pd-related-body">
              <h3 class="pd-related-name">{rp.title}</h3>
              <p class="pd-related-specs">
                {rp.voltage && rp.voltage !== 'N/A' ? rp.voltage : ''}
                {rp.voltage && rp.voltage !== 'N/A' && rp.torque && rp.torque !== 'N/A' ? ' · ' : ''}
                {rp.torque && rp.torque !== 'N/A' ? rp.torque : ''}
                {(!rp.torque || rp.torque === 'N/A') && rp.capacity ? rp.capacity : ''}
              </p>
              <span class="pd-related-link">Detayları Gör
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Lightbox Modal -->
<div class="pd-lightbox" id="pdLightbox">
  <div class="pd-lightbox-backdrop" id="pdLightboxBackdrop"></div>
  <div class="pd-lightbox-inner">
    <button class="pd-lightbox-close" id="pdLightboxClose" aria-label="Kapat">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
    <div class="pd-lightbox-img-wrap">
      <img src="" alt={product.title} class="pd-lightbox-img" id="pdLightboxImg" />
    </div>
    <div class="pd-lightbox-thumbs" id="pdLightboxThumbs">
      {product.imagesHd.map((hdUrl, idx) => (
        <button class={`pd-lightbox-thumb ${idx === 0 ? 'active' : ''}`} data-hd={hdUrl} data-index={idx}>
          <img src={product.images[idx]} alt={`${product.title} - ${idx + 1}`} />
        </button>
      ))}
    </div>
    <div class="pd-lightbox-nav">
      <button class="pd-lightbox-nav-btn" id="pdLightboxPrev" aria-label="Önceki">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="pd-lightbox-nav-btn" id="pdLightboxNext" aria-label="Sonraki">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</div>

<!-- Footer -->
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand"><img src="/img/logo/footer-logo.svg" alt="Voltz Power Tools" class="footer-logo"><p>Profesyonel el aletlerinde güvenin adresi.</p></div>
      <div class="footer-links"><h4>Sayfalar</h4><a href="/">Anasayfa</a><a href="/about">Hakkımızda</a><a href="/products">Ürünlerimiz</a><a href="/contact">İletişim</a></div>
      <div class="footer-links"><h4>Ürünler</h4><a href="/products">Matkaplar</a><a href="/products">Tornavidalar</a><a href="/products">Taşlama</a><a href="/v-pack">V-PACK Sistem</a></div>
