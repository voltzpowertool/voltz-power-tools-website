<script>
document.addEventListener('DOMContentLoaded', () => {
  const mainImage = document.getElementById('pdMainImage');
  const galleryMain = document.getElementById('pdGalleryMain');
  const thumbs = document.querySelectorAll('.pd-thumb');
  const zoomBtn = document.getElementById('pdZoomBtn');

  const lightbox = document.getElementById('pdLightbox');
  const lightboxImg = document.getElementById('pdLightboxImg');
  const lightboxClose = document.getElementById('pdLightboxClose');
  const lightboxBackdrop = document.getElementById('pdLightboxBackdrop');
  const lightboxThumbs = document.querySelectorAll('.pd-lightbox-thumb');
  const lightboxPrev = document.getElementById('pdLightboxPrev');
  const lightboxNext = document.getElementById('pdLightboxNext');

  let currentIndex = 0;
  const totalImages = thumbs.length;

  function setMainImage(idx) {
    currentIndex = idx;
    const thumb = thumbs[idx];
    if (!thumb || !mainImage) return;
    mainImage.src = thumb.dataset.image;
    mainImage.dataset.hdSrc = thumb.dataset.hd;
    thumbs.forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
  }

  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => setMainImage(parseInt(thumb.dataset.index)));
  });

  function openLightbox() {
    if (!lightbox) return;
    const hdSrc = mainImage?.dataset.hdSrc || mainImage?.src;
    if (lightboxImg) lightboxImg.src = hdSrc;
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
    updateLightboxThumbs();
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.remove('active');
    document.body.style.overflow = '';
  }

  function updateLightboxThumbs() {
    lightboxThumbs.forEach((t, i) => t.classList.toggle('active', i === currentIndex));
  }

  function setLightboxImage(idx) {
    currentIndex = idx;
    const lt = lightboxThumbs[idx];
    if (lt && lightboxImg) lightboxImg.src = lt.dataset.hd;
    updateLightboxThumbs();
    setMainImage(idx);
  }

  if (zoomBtn) zoomBtn.addEventListener('click', openLightbox);
  if (galleryMain) galleryMain.addEventListener('click', (e) => {
    if (e.target === zoomBtn || zoomBtn?.contains(e.target)) return;
    openLightbox();
  });
  if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
  if (lightboxBackdrop) lightboxBackdrop.addEventListener('click', closeLightbox);

  lightboxThumbs.forEach(t => {
    t.addEventListener('click', () => setLightboxImage(parseInt(t.dataset.index)));
  });

  if (lightboxPrev) lightboxPrev.addEventListener('click', () => {
    setLightboxImage((currentIndex - 1 + totalImages) % totalImages);
  });
  if (lightboxNext) lightboxNext.addEventListener('click', () => {
    setLightboxImage((currentIndex + 1) % totalImages);
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') setLightboxImage((currentIndex - 1 + totalImages) % totalImages);
    if (e.key === 'ArrowRight') setLightboxImage((currentIndex + 1) % totalImages);
  });

  let touchStartX = 0;
  if (lightbox) {
    lightbox.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0].screenX; });
    lightbox.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].screenX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) setLightboxImage((currentIndex + 1) % totalImages);
        else setLightboxImage((currentIndex - 1 + totalImages) % totalImages);
      }
    });
  }
});
</script>

