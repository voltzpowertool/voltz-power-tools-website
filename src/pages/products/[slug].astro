---
import Layout from '@/layouts/Layout.astro';
import productsData from '@/data/products.json';

// Generate static paths for all products
export async function getStaticPaths() {
  return productsData.map((product) => ({
    params: { slug: product.id },
    props: { product }
  }));
}

const { product } = Astro.props;

// Related products - intelligent selection
let relatedProducts = productsData
  .filter(p => p.category === product.category && p.id !== product.id)
  .slice(0, 3);

// If not enough products in same category, fill with other categories
if (relatedProducts.length < 2) {
  const otherProducts = productsData
    .filter(p => p.category !== product.category && p.id !== product.id)
    .slice(0, 3 - relatedProducts.length);
  relatedProducts = [...relatedProducts, ...otherProducts];
}

// Only show if we have at least 2 products
const shouldShowRelated = relatedProducts.length >= 2;

// Ensure we have a fallback title
const relatedTitle = relatedProducts.filter(p => p.category === product.category).length > 0 
  ? "Benzer" 
  : relatedProducts.length > 0 
    ? "Diğer" 
    : "Önerilen";

// Get category display name
function getCategoryName(category) {
  const categoryNames = {
    'drill': 'Akülü Darbeli Matkap',
    'driver': product.subcategory || 'Akülü Vidalama',
    'grinder': 'Akülü Taşlama',
    'hammer': 'Akülü Kırıcı Delici',
    'battery': product.subcategory || 'Batarya',
    'charger': product.subcategory || 'Şarj Cihazı',
    'storage': 'Taşıma Kutusu Sistemi'
  };
  return categoryNames[category] || product.subcategory || category;
}
---

<Layout 
  title={`${product.title} - ${getCategoryName(product.category)} | Voltz Power Tools`}
  description={`${product.title} ${getCategoryName(product.category)} özellikleri ve fiyatı. ${product.description} Brushless motor teknolojisi, V-PACK uyumlu batarya sistemi.`}
  keywords={`${product.title}, ${getCategoryName(product.category)}, voltz ${product.category}, ${product.voltage} alet, brushless motor, v-pack uyumlu`}
>

<!-- Breadcrumb -->
<section class="pd-breadcrumb-section">
  <div class="pd-container">
    <nav class="pd-breadcrumb" aria-label="Breadcrumb">
      <a href="/" class="pd-breadcrumb-link">ANASAYFA</a>
      <span class="pd-breadcrumb-sep">/</span>
      <a href="/products" class="pd-breadcrumb-link">ÜRÜNLER</a>
      <span class="pd-breadcrumb-sep">/</span>
      <span class="pd-breadcrumb-current">{product.title}</span>
    </nav>
  </div>
</section>

<!-- Product Hero: Two-Column Layout -->
<section class="pd-hero">
  <div class="pd-container">
    <div class="pd-hero-grid">

      <!-- LEFT: Image Gallery (60%) -->
      <div class="pd-gallery">
        <div class="pd-gallery-main" id="pdGalleryMain">
          <img 
            src={product.images[0]} 
            alt={product.title} 
            class="pd-gallery-main-img" 
            id="pdMainImage"
            data-hd-src={product.imagesHd[0]}
          />
          {product.voltage && product.voltage !== 'N/A' && product.category !== 'storage' && (
            <div class="pd-voltage-badge">
              <span class="pd-voltage-num">{product.voltage.replace('VDC', 'V')}</span>
              <span class="pd-voltage-label">V-PACK</span>
            </div>
          )}
          <button class="pd-zoom-btn" id="pdZoomBtn" aria-label="Büyüt">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>
          </button>
        </div>
        <div class="pd-gallery-thumbs" id="pdThumbs">
          {product.images.map((imgUrl, idx) => (
            <button 
              class={`pd-thumb ${idx === 0 ? 'active' : ''}`} 
              data-image={imgUrl} 
              data-hd={product.imagesHd[idx]}
              data-index={idx}
              aria-label={`Görsel ${idx + 1}`}
            >
              <img src={imgUrl} alt={`${product.title} - Görsel ${idx + 1}`} />
            </button>
          ))}
        </div>
      </div>

      <!-- RIGHT: Product Info (40%) -->
      <div class="pd-info">
        <div class="pd-badges">
          {product.category !== 'battery' && product.category !== 'charger' && product.category !== 'storage' && (
            <span class="pd-badge pd-badge-green">BRUSHLESS</span>
          )}
          {(product.category === 'drill' || product.category === 'driver' || product.category === 'hammer' || product.category === 'grinder') && (
            <span class="pd-badge pd-badge-dark">HEAVY DUTY</span>
          )}
          {product.voltage && product.voltage !== 'N/A' && (
            <span class="pd-badge pd-badge-outline">{product.voltage}</span>
          )}
        </div>

        <h1 class="pd-title">{product.title}</h1>
        <p class="pd-category">{getCategoryName(product.category)}</p>
        <p class="pd-description">{product.description}</p>

        <!-- Key Specs Grid -->
        <div class="pd-key-specs">
          {product.voltage && product.voltage !== 'N/A' && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">VOLTAJ</span>
              <span class="pd-key-spec-value">{product.voltage}</span>
            </div>
          )}
          {product.torque && product.torque !== 'N/A' && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">TORK</span>
              <span class="pd-key-spec-value">{product.torque}</span>
            </div>
          )}
          {product.speed && product.speed !== 'N/A' && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">HIZ</span>
              <span class="pd-key-spec-value">{product.speed}</span>
            </div>
          )}
          {product.weight && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">AĞIRLIK</span>
              <span class="pd-key-spec-value">{product.weight}</span>
            </div>
          )}
          {product.chuck && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">{product.category === 'drill' ? 'MANDREN' : 'BAĞLANTI'}</span>
              <span class="pd-key-spec-value">{product.chuck}</span>
            </div>
          )}
          {product.bpm && product.bpm !== 'N/A' && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">DARBE</span>
              <span class="pd-key-spec-value">{product.bpm}</span>
            </div>
          )}
          {product.diskSize && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">DİSK ÇAPI</span>
              <span class="pd-key-spec-value">{product.diskSize}</span>
            </div>
          )}
          {product.capacity && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">KAPASİTE</span>
              <span class="pd-key-spec-value">{product.capacity}</span>
            </div>
          )}
          {product.energy && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">ENERJİ</span>
              <span class="pd-key-spec-value">{product.energy}</span>
            </div>
          )}
          {product.current && (
            <div class="pd-key-spec">
              <span class="pd-key-spec-label">ÇIKIŞ</span>
              <span class="pd-key-spec-value">{product.current}</span>
            </div>
          )}
        </div>

        <!-- Features Checklist -->
        {product.features && product.features.length > 0 && (
          <div class="pd-features">
            <h3 class="pd-features-title">ÖZELLİKLER</h3>
            <ul class="pd-features-list">
              {product.features.map((feature) => (
                <li class="pd-feature-item">
                  <svg class="pd-check-icon" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6BE03F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<!-- Package Contents -->
<section class="pd-package-section">
  <div class="pd-container">

    {product.batteryIncluded && product.category !== 'storage' && product.category !== 'battery' && product.category !== 'charger' && (
      <div class="pd-package-card">
        <div class="pd-package-header">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6BE03F" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          <h3>PAKET İÇERİĞİ</h3>
        </div>
        <div class="pd-package-grid">
          <div class="pd-package-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6BE03F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>1x {product.title}</span>
          </div>
          <div class="pd-package-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6BE03F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>2x {product.voltage} Batarya</span>
          </div>
          <div class="pd-package-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6BE03F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>1x Hızlı Şarj Cihazı</span>
          </div>
          <div class="pd-package-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6BE03F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Kullanım Kılavuzu</span>
          </div>
          <div class="pd-package-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6BE03F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Garanti Belgesi</span>
          </div>
        </div>
        <div class="pd-package-vpack">
          <span class="pd-vpack-tag">V-PACK</span> Uyumlu Sistem
        </div>
      </div>
    )}

    {product.category === 'battery' && (
      <div class="pd-package-card">
        <div class="pd-package-header">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6BE03F" stroke-width="2"><rect x="1" y="6" width="18" height="12" rx="0" ry="0"/><line x1="23" y1="13" x2="23" y2="11"/></svg>
          <h3>BATARYA ÖZELLİKLERİ</h3>
        </div>
        <div class="pd-battery-specs">
          <div class="pd-battery-stat">
            <span class="pd-battery-stat-value">{product.voltage}</span>
            <span class="pd-battery-stat-label">VOLTAJ</span>
          </div>
          {product.capacity && (
            <div class="pd-battery-stat">
              <span class="pd-battery-stat-value">{product.capacity}</span>
              <span class="pd-battery-stat-label">KAPASİTE</span>
            </div>
          )}
          {product.energy && (
            <div class="pd-battery-stat">
              <span class="pd-battery-stat-value">{product.energy}</span>
              <span class="pd-battery-stat-label">ENERJİ</span>
            </div>
          )}
        </div>
      </div>
    )}

    {product.category === 'charger' && (
      <div class="pd-package-card">
        <div class="pd-package-header">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6BE03F" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          <h3>ŞARJ CİHAZI ÖZELLİKLERİ</h3>
        </div>
        <div class="pd-battery-specs">
          {product.voltage && (
            <div class="pd-battery-stat">
              <span class="pd-battery-stat-value">{product.voltage}</span>
              <span class="pd-battery-stat-label">VOLTAJ</span>
            </div>
          )}
          {product.current && (
            <div class="pd-battery-stat">
              <span class="pd-battery-stat-value">{product.current}</span>
              <span class="pd-battery-stat-label">ÇIKIŞ</span>
            </div>
          )}
        </div>
      </div>
    )}

    {product.category === 'storage' && (
      <div class="pd-package-card">
        <div class="pd-package-header">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6BE03F" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="0" ry="0"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          <h3>SİSTEM ÖZELLİKLERİ</h3>
        </div>
        <div class="pd-storage-features">
          <div class="pd-storage-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6BE03F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Modüler İstiflenebilir</span>
          </div>
          <div class="pd-storage-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6BE03F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Güvenli Kilit Sistemi</span>
          </div>
          <div class="pd-storage-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6BE03F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Ergonomik Taşıma</span>
          </div>
        </div>
      </div>
    )}

  </div>
</section>

<!-- Related Products -->
{shouldShowRelated && (
  <section class="pd-related-section">
    <div class="pd-container">
      <h2 class="pd-section-title">{relatedTitle} <span class="pd-highlight">ÜRÜNLER</span></h2>
      <div class={`pd-related-grid ${relatedProducts.length === 2 ? 'pd-related-two' : ''}`}>
        {relatedProducts.map((rp) => (
          <a href={`/products/${rp.id}`} class="pd-related-card">
            <div class="pd-related-img-wrap">
              <img src={rp.images?.[0] || rp.image} alt={rp.title} class="pd-related-img" />
              {rp.voltage && rp.voltage !== 'N/A' && rp.category !== 'storage' && (
                <span class="pd-related-voltage">{rp.voltage}</span>
              )}
            </div>
            <div class="pd-related-body">
              <span class="pd-related-sub">{rp.subcategory}</span>
              <h3 class="pd-related-name">{rp.title}</h3>
              <span class="pd-related-link">DETAYLAR &gt;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Lightbox Modal -->
<div class="pd-lightbox" id="pdLightbox">
  <div class="pd-lightbox-backdrop" id="pdLightboxBackdrop"></div>
  <div class="pd-lightbox-inner">
    <button class="pd-lightbox-close" id="pdLightboxClose" aria-label="Kapat">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
    <div class="pd-lightbox-img-wrap">
      <img src="" alt={product.title} class="pd-lightbox-img" id="pdLightboxImg" />
    </div>
    <div class="pd-lightbox-thumbs" id="pdLightboxThumbs">
      {product.imagesHd.map((hdUrl, idx) => (
        <button class={`pd-lightbox-thumb ${idx === 0 ? 'active' : ''}`} data-hd={hdUrl} data-index={idx}>
          <img src={product.images[idx]} alt={`${product.title} - ${idx + 1}`} />
        </button>
      ))}
    </div>
    <div class="pd-lightbox-nav">
      <button class="pd-lightbox-nav-btn" id="pdLightboxPrev" aria-label="Önceki">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="pd-lightbox-nav-btn" id="pdLightboxNext" aria-label="Sonraki">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</div>

<!-- Footer -->
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand"><img src="/img/logo/footer-logo.svg" alt="Voltz" class="footer-logo"><p>Profesyonel el aletlerinde güvenin adresi.</p></div>
      <div class="footer-links"><h4>Sayfalar</h4><a href="/">Anasayfa</a><a href="/about">Hakkımızda</a><a href="/products">Ürünlerimiz</a><a href="/contact">İletişim</a></div>
      <div class="footer-links"><h4>Ürünler</h4><a href="/products">Matkaplar</a><a href="/products">Tornavidalar</a><a href="/products">Taşlama</a><a href="/v-pack">V-PACK</a></div>
      <div class="footer-contact-col"><h4>İletişim</h4><p>Teknoloji Caddesi No: 123<br>Sanayi Mahallesi, İstanbul</p><a href="mailto:info@voltzpowertools.com">info@voltzpowertools.com</a><a href="tel:+902123456789">+90 212 345 67 89</a></div>
    </div>
    <div class="footer-bottom"><p>© 2025 Voltz Power Tools. Tüm hakları saklıdır.</p><div class="footer-social"><a href="#">LI</a><a href="#">IG</a></div></div>
  </div>
</footer>

</Layout>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const mainImage = document.getElementById('pdMainImage');
  const galleryMain = document.getElementById('pdGalleryMain');
  const thumbs = document.querySelectorAll('.pd-thumb');
  const zoomBtn = document.getElementById('pdZoomBtn');

  const lightbox = document.getElementById('pdLightbox');
  const lightboxImg = document.getElementById('pdLightboxImg');
  const lightboxClose = document.getElementById('pdLightboxClose');
  const lightboxBackdrop = document.getElementById('pdLightboxBackdrop');
  const lightboxThumbs = document.querySelectorAll('.pd-lightbox-thumb');
  const lightboxPrev = document.getElementById('pdLightboxPrev');
  const lightboxNext = document.getElementById('pdLightboxNext');

  let currentIndex = 0;
  const totalImages = thumbs.length;

  function setMainImage(idx) {
    currentIndex = idx;
    const thumb = thumbs[idx];
    if (!thumb || !mainImage) return;
    mainImage.src = thumb.dataset.image;
    mainImage.dataset.hdSrc = thumb.dataset.hd;
    thumbs.forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
  }

  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => setMainImage(parseInt(thumb.dataset.index)));
  });

  function openLightbox() {
    if (!lightbox) return;
    const hdSrc = mainImage?.dataset.hdSrc || mainImage?.src;
    if (lightboxImg) lightboxImg.src = hdSrc;
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
    updateLightboxThumbs();
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.remove('active');
    document.body.style.overflow = '';
  }

  function updateLightboxThumbs() {
    lightboxThumbs.forEach((t, i) => t.classList.toggle('active', i === currentIndex));
  }

  function setLightboxImage(idx) {
    currentIndex = idx;
    const lt = lightboxThumbs[idx];
    if (lt && lightboxImg) lightboxImg.src = lt.dataset.hd;
    updateLightboxThumbs();
    setMainImage(idx);
  }

  if (zoomBtn) zoomBtn.addEventListener('click', openLightbox);
  if (galleryMain) galleryMain.addEventListener('click', (e) => {
    if (e.target === zoomBtn || zoomBtn?.contains(e.target)) return;
    openLightbox();
  });
  if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
  if (lightboxBackdrop) lightboxBackdrop.addEventListener('click', closeLightbox);

  lightboxThumbs.forEach(t => {
    t.addEventListener('click', () => setLightboxImage(parseInt(t.dataset.index)));
  });

  if (lightboxPrev) lightboxPrev.addEventListener('click', () => {
    setLightboxImage((currentIndex - 1 + totalImages) % totalImages);
  });
  if (lightboxNext) lightboxNext.addEventListener('click', () => {
    setLightboxImage((currentIndex + 1) % totalImages);
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') setLightboxImage((currentIndex - 1 + totalImages) % totalImages);
    if (e.key === 'ArrowRight') setLightboxImage((currentIndex + 1) % totalImages);
  });

  let touchStartX = 0;
  if (lightbox) {
    lightbox.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0].screenX; });
    lightbox.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].screenX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) setLightboxImage((currentIndex + 1) % totalImages);
        else setLightboxImage((currentIndex - 1 + totalImages) % totalImages);
      }
    });
  }
});
</script>

<style>
/* =====================================================
   PRODUCT DETAIL — SHARP INDUSTRIAL DESIGN
   ===================================================== */

:root {
  --green: #6BE03F;
  --dark: #1A1A1A;
  --darker: #111111;
  --gray-900: #2D2D2D;
  --gray-700: #4A4A4A;
  --gray-500: #7A7A7A;
  --gray-100: #F5F6F8;
  --white: #FFFFFF;
  --border: #E5E7EB;
}

.pd-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 40px;
}

/* ── BREADCRUMB ── */
.pd-breadcrumb-section {
  padding: 100px 0 0;
  background: var(--white);
}

.pd-breadcrumb {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: 'GeneralSans-Bold', sans-serif;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.pd-breadcrumb-link {
  color: var(--gray-500);
  text-decoration: none;
  transition: color 0.2s;
}

.pd-breadcrumb-link:hover {
  color: var(--green);
}

.pd-breadcrumb-sep {
  color: var(--gray-500);
  opacity: 0.4;
  font-size: 13px;
}

.pd-breadcrumb-current {
  color: var(--green);
  font-family: 'GeneralSans-Bold', sans-serif;
  font-weight: 700;
}

/* ── HERO: TWO-COLUMN ── */
.pd-hero {
  padding: 40px 0 60px;
  background: var(--white);
}

.pd-hero-grid {
  display: grid;
  grid-template-columns: 3fr 2fr;
  gap: 60px;
  align-items: start;
}

/* ── GALLERY ── */
.pd-gallery {
  position: sticky;
  top: 100px;
}

.pd-gallery-main {
  position: relative;
