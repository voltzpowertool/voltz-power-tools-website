---
import Layout from '@/layouts/Layout.astro';
---

<Layout 
  title="İletişim - Voltz Power Tools | Bize Ulaşın"
  description="Voltz Power Tools ile iletişime geçin. Ürünlerimiz hakkında bilgi alın, fiyat teklifi isteyin veya teknik destek alın."
  keywords="voltz iletişim, power tools destek, akülü alet servisi, fiyat teklifi, teknik destek, müşteri hizmetleri"
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <span class="section-tag">İLETİŞİM</span>
        <h1>Sizinle <span class="text-green">Konuşalım</span></h1>
        <p class="page-hero-desc">Ürünlerimiz hakkında bilgi almak, fiyat teklifi istemek veya teknik destek için bizimle iletişime geçin.</p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">

        <!-- LEFT: Contact Form -->
        <div class="contact-form-wrap">
          <h2>Mesaj Gönderin</h2>
          <p class="form-subtitle">Formu doldurarak bize ulaşın, en kısa sürede size geri döneceğiz.</p>

          <form class="contact-form" id="contactForm">
            <div class="form-group">
              <label for="fullName">Ad Soyad *</label>
              <input type="text" id="fullName" name="fullName" required placeholder="Adınız ve soyadınız" />
            </div>

            <div class="form-group">
              <label for="email">E-posta *</label>
              <input type="email" id="email" name="email" required placeholder="ornek@email.com" />
            </div>

            <div class="form-group">
              <label for="subject">Konu *</label>
              <select id="subject" name="subject" required>
                <option value="">Konu seçin</option>
                <option value="genel">Genel</option>
                <option value="urun">Ürün Bilgisi</option>
                <option value="bayilik">Bayilik</option>
                <option value="destek">Teknik Destek</option>
                <option value="diger">Diğer</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Mesaj *</label>
              <textarea id="message" name="message" rows="5" required placeholder="Mesajınızı buraya yazın..."></textarea>
            </div>

            <div class="form-checkbox">
              <input type="checkbox" id="kvkk" name="kvkk" required />
              <label for="kvkk">Kişisel verilerimin işlenmesine ve iletişim kurulmasına onay veriyorum. *</label>
            </div>

            <button type="submit" class="btn-submit">
              GÖNDER
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </button>
          </form>
        </div>

        <!-- RIGHT: Contact Info -->
        <div class="contact-info-wrap">
          <h2>İletişim Bilgileri</h2>
          <p class="info-subtitle">Aşağıdaki bilgilerden bize doğrudan ulaşabilirsiniz.</p>

          <div class="info-cards">
            <!-- Address -->
            <div class="info-card">
              <div class="info-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="info-card-body">
                <h4>Adres</h4>
                <p>Teknoloji Caddesi No: 123<br>Sanayi Mahallesi, İstanbul<br>Türkiye 34000</p>
              </div>
            </div>

            <!-- Phone -->
            <div class="info-card">
              <div class="info-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div class="info-card-body">
                <h4>Telefon</h4>
                <p><a href="tel:+902123456789">+90 212 345 67 89</a></p>
              </div>
            </div>

            <!-- Email -->
            <div class="info-card">
              <div class="info-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div class="info-card-body">
                <h4>E-posta</h4>
                <p><a href="mailto:info@voltzpowertools.com">info@voltzpowertools.com</a></p>
              </div>
            </div>

            <!-- Working Hours -->
            <div class="info-card">
              <div class="info-card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div class="info-card-body">
                <h4>Çalışma Saatleri</h4>
                <p>Pazartesi – Cuma: 09:00 – 18:00<br>Cumartesi: 09:00 – 13:00<br>Pazar: Kapalı</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="map-section">
    <div class="container">
      <div class="map-header">
        <span class="section-tag">KONUM</span>
        <h2>Bizi Ziyaret Edin</h2>
      </div>
      <div class="map-wrap">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3010.2449380982657!2d28.97953731526943!3d41.01546357929856!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14cab9bd6570f4e1%3A0x8239b5fdc8b6c9ec!2sTaksim%20Square!5e0!3m2!1sen!2str!4v1635789012345!5m2!1sen!2str"
          width="100%"
          height="420"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Voltz Power Tools Konum">
        </iframe>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand"><img src="/img/logo/footer-logo.svg" alt="Voltz Power Tools" class="footer-logo"><p>Profesyonel el aletlerinde güvenin adresi.</p></div>
        <div class="footer-links"><h4>Sayfalar</h4><a href="/">Anasayfa</a><a href="/about">Hakkımızda</a><a href="/products">Ürünlerimiz</a><a href="/contact">İletişim</a></div>
        <div class="footer-links"><h4>Ürünler</h4><a href="/products">Matkaplar</a><a href="/products">Tornavidalar</a><a href="/products">Taşlama</a><a href="/v-pack">V-PACK Sistem</a></div>
        <div class="footer-contact-col"><h4>İletişim</h4><p>Teknoloji Caddesi No: 123<br>Sanayi Mahallesi, İstanbul</p><a href="mailto:info@voltzpowertools.com">info@voltzpowertools.com</a><a href="tel:+902123456789">+90 212 345 67 89</a></div>
      </div>
      <div class="footer-bottom"><p>&copy; 2025 Voltz Power Tools. Tüm hakları saklıdır.</p><div class="footer-social"><a href="#" aria-label="LinkedIn"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a><a href="#" aria-label="Instagram"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a></div></div>
    </div>
  </footer>

</Layout>

<style>
  .text-green { color: var(--green); }

  .section-tag {
    display: inline-block;
    padding: 4px 14px;
    background: rgba(107, 224, 63, 0.1);
    color: var(--green-dark);
    font-family: 'GeneralSans-Semibold', sans-serif;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 1.5px;
    border-radius: 100px;
    margin-bottom: 16px;
  }

  /* ========== PAGE HERO ========== */
  .page-hero {
    padding: 80px 0 64px;
    background: var(--gray-100);
    text-align: center;
  }

  .page-hero-inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .page-hero h1 {
    margin-bottom: 20px;
  }

  .page-hero-desc {
    font-size: 18px;
    line-height: 1.7;
    color: var(--gray-500);
    max-width: 540px;
    margin: 0 auto;
  }

  /* ========== CONTACT SECTION ========== */
  .contact-section {
    padding: 100px 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 72px;
    align-items: flex-start;
  }

  .contact-form-wrap h2,
  .contact-info-wrap h2 {
    margin-bottom: 8px;
  }

  .form-subtitle,
  .info-subtitle {
    font-size: 15px;
    line-height: 1.6;
    color: var(--gray-500);
    margin-bottom: 36px;
  }

  /* Form Styles */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-family: 'GeneralSans-Semibold', sans-serif;
    font-weight: 600;
    font-size: 13px;
    color: var(--dark);
    letter-spacing: 0.3px;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 14px 16px;
    background: var(--gray-100);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: 'GeneralSans-Variable', sans-serif;
    font-size: 15px;
    color: var(--dark);
    transition: all var(--transition);
    outline: none;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--gray-500);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--green);
    background: var(--white);
    box-shadow: 0 0 0 3px rgba(107, 224, 63, 0.1);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-group select {
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%237A7A7A' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: 40px;
  }

  .form-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .form-checkbox input[type="checkbox"] {
    width: 18px;
    height: 18px;
    margin-top: 2px;
    accent-color: var(--green);
    flex-shrink: 0;
    cursor: pointer;
  }

  .form-checkbox label {
    font-size: 13px;
    line-height: 1.5;
    color: var(--gray-500);
    cursor: pointer;
  }

  .btn-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px 40px;
    background: var(--green);
    color: var(--dark);
    border: none;
    border-radius: var(--radius-sm);
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all var(--transition);
    align-self: flex-start;
  }

  .btn-submit:hover {
    background: var(--green-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-green);
  }

  .btn-submit:active {
    transform: translateY(0);
  }

  .btn-submit svg {
    transition: transform var(--transition);
  }

  .btn-submit:hover svg {
    transform: translateX(3px);
  }

  /* Info Cards */
  .info-cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .info-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 24px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: all var(--transition);
  }

  .info-card:hover {
    border-color: var(--green);
    box-shadow: var(--shadow-sm);
  }

  .info-card-icon {
    width: 48px;
    height: 48px;
    background: rgba(107, 224, 63, 0.1);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--green);
    flex-shrink: 0;
  }

  .info-card-body h4 {
    font-family: 'GeneralSans-Semibold', sans-serif;
    font-weight: 600;
    font-size: 15px;
    color: var(--dark);
    margin-bottom: 6px;
  }

  .info-card-body p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--gray-500);
  }

  .info-card-body a {
    color: var(--green-dark);
    text-decoration: none;
    transition: color var(--transition);
  }

  .info-card-body a:hover {
    color: var(--green);
  }

  /* ========== MAP SECTION ========== */
  .map-section {
    padding: 0 0 100px;
  }

  .map-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .map-header h2 {
    margin-bottom: 0;
  }

  .map-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .map-wrap iframe {
    display: block;
    width: 100%;
    height: 420px;
  }

  /* ========== FOOTER ========== */
  .site-footer { background: var(--dark, #1A1A1A); padding: 64px 0 32px; color: #fff; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 48px; padding-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .footer-logo { height: 48px; width: auto; display: block; margin-bottom: 16px; }
  .footer-brand p { font-size: 14px; line-height: 1.7; color: rgba(255,255,255,0.6); }
  .footer-links h4, .footer-contact-col h4 { font-family: 'GeneralSans-Bold', sans-serif; font-size: 14px; color: var(--green, #6BE03F); margin-bottom: 16px; }
  .footer-links a, .footer-contact-col a { display: block; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 14px; padding: 4px 0; transition: color 0.25s ease; }
  .footer-links a:hover, .footer-contact-col a:hover { color: var(--green, #6BE03F); }
  .footer-contact-col p { font-size: 14px; line-height: 1.6; color: rgba(255,255,255,0.6); margin-bottom: 12px; }
  .footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 24px; }
  .footer-bottom p { font-size: 13px; color: rgba(255,255,255,0.4); }
  .footer-social { display: flex; gap: 12px; }
  .footer-social a { display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; background: rgba(255,255,255,0.08); border-radius: 50%; color: rgba(255,255,255,0.6); transition: all 0.25s ease; }
  .footer-social a:hover { background: var(--green, #6BE03F); color: var(--dark, #1A1A1A); }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 1024px) {
    .contact-grid {
      gap: 48px;
    }
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 56px 0 48px;
    }

    .page-hero-desc {
      font-size: 16px;
    }

    .contact-section {
      padding: 64px 0;
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: 56px;
    }

    .btn-submit {
      width: 100%;
      justify-content: center;
    }

    .map-section {
      padding: 0 0 64px;
    }

    .map-wrap iframe {
      height: 300px;
    }

    .footer-grid { grid-template-columns: 1fr; text-align: center; }
    .footer-bottom { flex-direction: column; gap: 16px; text-align: center; }
    .footer-social { justify-content: center; }
  }

  @media (max-width: 480px) {
    .info-card {
      flex-direction: column;
      text-align: center;
      align-items: center;
    }

    .map-wrap iframe {
      height: 240px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      if (!data.fullName || !data.email || !data.subject || !data.message) {
        showToast('Lütfen tüm zorunlu alanları doldurun.', 'error');
        return;
      }

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(data.email)) {
        showToast('Lütfen geçerli bir e-posta adresi girin.', 'error');
        return;
      }

      if (!data.kvkk) {
        showToast('Lütfen KVKK onay kutusunu işaretleyin.', 'error');
        return;
      }

      const btn = form.querySelector('.btn-submit');
      const origText = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = 'GÖNDERİLİYOR...';
      btn.style.opacity = '0.7';

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });
        const result = await response.json();

        if (result.success) {
          showToast(result.message, 'success');
          form.reset();
        } else {
          showToast(result.message, 'error');
        }
      } catch {
        showToast('Mesaj gönderilirken bir hata oluştu. Lütfen tekrar deneyin.', 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = origText;
        btn.style.opacity = '1';
      }
    });

    function showToast(message, type) {
      const existing = document.querySelectorAll('.toast-notification');
      existing.forEach((el) => el.remove());

      const toast = document.createElement('div');
      toast.className = 'toast-notification';
      toast.textContent = message;

      Object.assign(toast.style, {
        position: 'fixed',
        top: '24px',
        right: '24px',
        padding: '14px 24px',
        borderRadius: '8px',
        fontSize: '14px',
        fontWeight: '600',
        zIndex: '9999',
        maxWidth: '380px',
        boxShadow: '0 4px 16px rgba(0,0,0,0.12)',
        transform: 'translateX(120%)',
        transition: 'transform 0.3s ease',
        backgroundColor: type === 'success' ? '#6BE03F' : '#ff4444',
        color: type === 'success' ? '#1A1A1A' : '#fff',
      });

      document.body.appendChild(toast);
      requestAnimationFrame(() => { toast.style.transform = 'translateX(0)'; });

      setTimeout(() => {
        toast.style.transform = 'translateX(120%)';
        setTimeout(() => toast.remove(), 300);
      }, 4000);

      toast.addEventListener('click', () => {
        toast.style.transform = 'translateX(120%)';
        setTimeout(() => toast.remove(), 300);
      });
    }
  });
</script>
