---
import Layout from '@/layouts/Layout.astro';
import productsData from '@/data/products.json';

const categories = [
  { key: 'all', label: 'Tümü' },
  { key: 'drill', label: 'Matkaplar' },
  { key: 'driver', label: 'Vidalama' },
  { key: 'grinder', label: 'Taşlama' },
  { key: 'hammer', label: 'Kırıcı' },
  { key: 'battery', label: 'Batarya' },
  { key: 'charger', label: 'Şarj' },
  { key: 'storage', label: 'Taşıma' },
  { key: 'set', label: 'Setler' },
];
---

<Layout 
  title="Ürünler - Voltz Power Tools | Akülü El Aletleri Kataloğu"
  description="Voltz Power Tools tam ürün kataloğu. Brushless motor teknolojili akülü matkaplar, tornavidalar, taşlama makineleri, V-PACK batarya sistemi."
  keywords="voltz ürünler, akülü matkap, akülü tornavida, akülü taşlama, v-pack batarya, brushless motor"
>

  <section class="page-hero">
    <div class="hero-bg-overlay"></div>
    <div class="container">
      <div class="page-hero-inner">
        <span class="section-tag">ÜRÜN KATALOĞU</span>
        <h1>ÜRÜNLERİMİZ</h1>
        <p>Profesyonel işlerinizi bir üst seviyeye taşıyacak premium kalitede el aletleri.</p>
      </div>
    </div>
  </section>

  <section class="products-section">
    <div class="container">
      <div class="filter-bar">
        {categories.map((cat) => (
          <button class={`filter-btn ${cat.key === 'all' ? 'active' : ''}`} data-filter={cat.key}>
            {cat.label}
          </button>
        ))}
      </div>

      <div class="products-grid" id="productsGrid">
        {productsData.map((product) => (
          <a href={`/products/${product.id}`} class="product-card" data-category={product.category}>
            <div class="card-img">
              <img src={product.image} alt={product.title} loading="lazy">
              {product.voltage && <span class="voltage-badge">{product.voltage}</span>}
            </div>
            <div class="card-body">
              <span class="card-category">{product.subcategory}</span>
              <h3 class="card-title">{product.title}</h3>
              <span class="card-link">DETAYLAR &gt;</span>
            </div>
          </a>
        ))}
      </div>

      <div class="no-results" id="noResults" style="display:none">
        <h3>ÜRÜN BULUNAMADI</h3>
        <p>Bu kategoride henüz ürün bulunmuyor.</p>
      </div>
    </div>
  </section>

  <section class="vpack-cta">
    <div class="container">
      <div class="cta-card">
        <div class="cta-content">
          <span class="section-tag">V-PACK SİSTEMİ</span>
          <h2>TEK PLATFORM, SINIRSIZ GÜÇ</h2>
          <p>V-PACK batarya sistemi ile tüm aletleriniz aynı bataryayı kullanır. 20V ve 16.8V seçenekleriyle ihtiyacınıza uygun gücü seçin.</p>
          <a href="/v-pack" class="btn-primary">V-PACK'İ KEŞFET</a>
        </div>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand"><img src="/img/logo/voltz-symbol-green.png" alt="Voltz" class="footer-logo"><p>Profesyonel el aletlerinde güvenin adresi.</p></div>
        <div class="footer-links"><h4>Sayfalar</h4><a href="/">Anasayfa</a><a href="/about">Hakkımızda</a><a href="/products">Ürünlerimiz</a><a href="/contact">İletişim</a></div>
        <div class="footer-links"><h4>Ürünler</h4><a href="/products">Matkaplar</a><a href="/products">Tornavidalar</a><a href="/products">Taşlama</a><a href="/v-pack">V-PACK</a></div>
        <div class="footer-contact-col"><h4>İletişim</h4><p>Teknoloji Caddesi No: 123<br>Sanayi Mahallesi, İstanbul</p><a href="mailto:info@voltzpowertools.com">info@voltzpowertools.com</a><a href="tel:+902123456789">+90 212 345 67 89</a></div>
      </div>
      <div class="footer-bottom"><p>© 2025 Voltz Power Tools. Tüm hakları saklıdır.</p><div class="footer-social"><a href="#">LI</a><a href="#">IG</a></div></div>
    </div>
  </footer>

</Layout>

<style>
  :root {
    --green: #6BE03F;
    --dark: #1A1A1A;
    --darker: #111111;
    --gray-900: #2D2D2D;
    --gray-700: #4A4A4A;
    --gray-500: #7A7A7A;
    --gray-100: #F5F6F8;
    --white: #FFFFFF;
    --border: #E5E7EB;
  }

  /* ── HERO ── */
  .page-hero {
    position: relative;
    padding: 100px 0 80px;
    background: var(--dark);
    clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%);
    text-align: center;
    overflow: hidden;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: url('/voltzgorseller/03.png') center / cover no-repeat;
    opacity: 0.12;
    pointer-events: none;
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }

  .section-tag {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(107, 224, 63, 0.15);
    color: var(--green);
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .page-hero h1 {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: clamp(36px, 6vw, 56px);
    color: var(--white);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .page-hero p {
    font-size: 17px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
  }

  /* ── FILTER BAR ── */
  .products-section {
    padding: 64px 0 80px;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 40px;
    justify-content: center;
  }

  .filter-btn {
    padding: 10px 22px;
    background: transparent;
    border: 2px solid var(--dark);
    clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--dark);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-btn:hover {
    background: var(--dark);
    color: var(--green);
  }

  .filter-btn.active {
    background: var(--green);
    border-color: var(--green);
    color: var(--dark);
  }

  /* ── PRODUCTS GRID ── */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .product-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-left: 4px solid transparent;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .product-card.hidden { display: none; }

  .product-card:hover {
    border-left-color: var(--green);
    transform: translateY(-4px);
  }

  .card-img {
    position: relative;
    background: var(--gray-100);
    padding: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 200px;
  }

  .card-img img {
    max-width: 80%;
    max-height: 160px;
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  .product-card:hover .card-img img {
    transform: scale(1.05);
  }

  .voltage-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    padding: 5px 12px;
    background: var(--dark);
    color: var(--green);
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.5px;
  }

  .card-body {
    padding: 20px;
  }

  .card-category {
    font-size: 11px;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-family: 'GeneralSans-Semibold', sans-serif;
    font-weight: 600;
  }

  .card-title {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 16px;
    color: var(--dark);
    margin: 6px 0 16px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .card-link {
    display: inline-block;
    color: var(--green);
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 1px;
    transition: letter-spacing 0.2s ease;
  }

  .product-card:hover .card-link {
    letter-spacing: 2px;
  }

  .no-results {
    text-align: center;
    padding: 80px 0;
  }

  .no-results h3 {
    margin-bottom: 8px;
    color: var(--dark);
    font-family: 'GeneralSans-Bold', sans-serif;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .no-results p {
    color: var(--gray-500);
  }

  /* ── V-PACK CTA ── */
  .vpack-cta {
    padding: 0 0 80px;
  }

  .cta-card {
    background: var(--dark);
    padding: 56px;
    text-align: center;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 24px), calc(100% - 24px) 100%, 0 100%);
  }

  .cta-card .section-tag {
    background: rgba(107, 224, 63, 0.15);
  }

  .cta-card h2 {
    color: var(--white);
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: clamp(24px, 4vw, 36px);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .cta-card p {
    color: rgba(255, 255, 255, 0.6);
    font-size: 16px;
    line-height: 1.7;
    max-width: 520px;
    margin: 0 auto 28px;
  }

  .btn-primary {
    display: inline-block;
    padding: 14px 32px;
    background: var(--green);
    color: var(--dark);
    text-decoration: none;
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
    transition: all 0.25s ease;
  }

  .btn-primary:hover {
    background: var(--white);
    color: var(--dark);
  }

  /* ── FOOTER ── */
  .site-footer {
    background: var(--darker);
    padding: 64px 0 32px;
    color: #fff;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-logo { height: 48px; width: auto; display: block; margin-bottom: 16px; }
  .footer-brand p { font-size: 14px; line-height: 1.7; color: rgba(255, 255, 255, 0.5); }

  .footer-links h4,
  .footer-contact-col h4 {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-size: 13px;
    color: var(--green);
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  .footer-links a,
  .footer-contact-col a {
    display: block;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    font-size: 14px;
    padding: 4px 0;
    transition: color 0.2s ease;
  }

  .footer-links a:hover,
  .footer-contact-col a:hover { color: var(--green); }

  .footer-contact-col p {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 12px;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
  }

  .footer-bottom p { font-size: 13px; color: rgba(255, 255, 255, 0.3); }

  .footer-social { display: flex; gap: 12px; }

  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.5px;
    transition: all 0.2s ease;
  }

  .footer-social a:hover {
    background: var(--green);
    color: var(--dark);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .products-grid { grid-template-columns: repeat(3, 1fr); }
    .footer-grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
  }

  @media (max-width: 768px) {
    .page-hero { padding: 80px 0 64px; clip-path: polygon(0 0, 100% 0, 100% 90%, 0 100%); }
    .products-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .card-img { height: 160px; padding: 16px; }
    .cta-card { padding: 32px 24px; clip-path: polygon(0 0, 100% 0, 100% calc(100% - 16px), calc(100% - 16px) 100%, 0 100%); }
    .footer-grid { grid-template-columns: 1fr; text-align: center; }
    .footer-logo { margin: 0 auto 16px; }
    .footer-bottom { flex-direction: column; gap: 16px; text-align: center; }
    .footer-social { justify-content: center; }
  }

  @media (max-width: 480px) {
    .products-grid { grid-template-columns: 1fr; }
    .filter-bar { gap: 8px; }
    .filter-btn { padding: 8px 16px; font-size: 11px; }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.product-card');
  const noResults = document.getElementById('noResults');

  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filterBtns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');

      const filter = btn.getAttribute('data-filter');
      let visible = 0;

      cards.forEach(function(card) {
        const category = card.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          card.classList.remove('hidden');
          card.style.display = '';
          visible++;
        } else {
          card.classList.add('hidden');
          card.style.display = 'none';
        }
      });

      noResults.style.display = visible === 0 ? 'block' : 'none';
    });
  });
});
</script>
