---
import Layout from '@/layouts/Layout.astro';
import productsData from '@/data/products.json';

const categories = [
  { key: 'all', label: 'Tümü' },
  { key: 'drill', label: 'Matkaplar' },
  { key: 'driver', label: 'Vidalama' },
  { key: 'grinder', label: 'Taşlama' },
  { key: 'hammer', label: 'Kırıcı' },
  { key: 'battery', label: 'Batarya' },
  { key: 'charger', label: 'Şarj' },
  { key: 'storage', label: 'Taşıma' },
];
---

<Layout 
  title="Ürünler - Voltz Power Tools | Akülü El Aletleri Kataloğu"
  description="Voltz Power Tools tam ürün kataloğu. Brushless motor teknolojili akülü matkaplar, tornavidalar, taşlama makineleri, V-PACK batarya sistemi."
  keywords="voltz ürünler, akülü matkap, akülü tornavida, akülü taşlama, v-pack batarya, brushless motor"
>

  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <span class="section-tag">ÜRÜN KATALOĞU</span>
        <h1>Ürünlerimiz</h1>
        <p>Profesyonel işlerinizi bir üst seviyeye taşıyacak premium kalitede el aletleri. Her ürün V-PACK batarya sistemi ile uyumlu.</p>
      </div>
    </div>
  </section>

  <section class="products-section">
    <div class="container">
      <div class="filter-bar">
        {categories.map((cat) => (
          <button class={`filter-btn ${cat.key === 'all' ? 'active' : ''}`} data-filter={cat.key}>
            {cat.label}
          </button>
        ))}
      </div>

      <div class="products-grid" id="productsGrid">
        {productsData.map((product) => (
          <a href={`/products/${product.id}`} class="product-card" data-category={product.category}>
            <div class="card-img">
              <img src={product.image} alt={product.title} loading="lazy">
              {product.voltage && <span class="voltage-badge">{product.voltage}</span>}
            </div>
            <div class="card-body">
              <span class="card-category">{product.subcategory}</span>
              <h3 class="card-title">{product.title}</h3>
              <p class="card-desc">{product.description}</p>
              <div class="card-specs">
                {product.torque && <span class="spec"><strong>Tork:</strong> {product.torque}</span>}
                {product.speed && <span class="spec"><strong>Hız:</strong> {product.speed}</span>}
                {product.weight && <span class="spec"><strong>Ağırlık:</strong> {product.weight}</span>}
              </div>
              <div class="card-footer">
                <span class="card-link">
                  Detaylar
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="no-results" id="noResults" style="display:none">
        <h3>Ürün Bulunamadı</h3>
        <p>Bu kategoride henüz ürün bulunmuyor.</p>
      </div>
    </div>
  </section>

  <section class="vpack-cta">
    <div class="container">
      <div class="cta-card">
        <div class="cta-content">
          <span class="section-tag">V-PACK SİSTEMİ</span>
          <h2>Tek Platform, Sınırsız Güç</h2>
          <p>V-PACK batarya sistemi ile tüm aletleriniz aynı bataryayı kullanır. 20V ve 16.8V seçenekleriyle ihtiyacınıza uygun gücü seçin.</p>
          <a href="/v-pack" class="btn-primary">
            V-PACK'İ KEŞFET
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <img src="/img/logo/footer-logo.svg" alt="Voltz Power Tools" class="footer-logo">
          <p>Profesyonel el aletlerinde güvenin adresi.</p>
        </div>
        <div class="footer-links">
          <h4>Sayfalar</h4>
          <a href="/">Anasayfa</a>
          <a href="/about">Hakkımızda</a>
          <a href="/products">Ürünlerimiz</a>
          <a href="/contact">İletişim</a>
        </div>
        <div class="footer-links">
          <h4>Ürünler</h4>
          <a href="/products">Matkaplar</a>
          <a href="/products">Tornavidalar</a>
          <a href="/products">Taşlama</a>
          <a href="/v-pack">V-PACK Sistem</a>
        </div>
        <div class="footer-contact-col">
          <h4>İletişim</h4>
          <p>Teknoloji Caddesi No: 123<br>Sanayi Mahallesi, İstanbul</p>
          <a href="mailto:info@voltzpowertools.com">info@voltzpowertools.com</a>
          <a href="tel:+902123456789">+90 212 345 67 89</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2025 Voltz Power Tools. Tüm hakları saklıdır.</p>
        <div class="footer-social">
          <a href="#" aria-label="LinkedIn"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
          <a href="#" aria-label="Instagram"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
        </div>
      </div>
    </div>
  </footer>

</Layout>

<style>
  .section-tag {
    display: inline-block;
    padding: 4px 14px;
    background: rgba(107, 224, 63, 0.1);
    color: var(--green-dark, #5BC935);
    font-family: 'GeneralSans-Semibold', sans-serif;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 1.5px;
    border-radius: 100px;
    margin-bottom: 16px;
  }

  .page-hero {
    padding: 60px 0 48px;
    background: var(--gray-100, #F5F6F8);
    text-align: center;
  }

  .page-hero-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .page-hero h1 {
    margin-bottom: 16px;
  }

  .page-hero p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--gray-500, #7A7A7A);
  }

  .products-section {
    padding: 48px 0 80px;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 40px;
    justify-content: center;
  }

  .filter-btn {
    padding: 8px 20px;
    background: var(--white, #fff);
    border: 1.5px solid var(--border, #E5E7EB);
    border-radius: 100px;
    font-family: 'GeneralSans-Semibold', sans-serif;
    font-weight: 600;
    font-size: 13px;
    color: var(--gray-700, #4A4A4A);
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .filter-btn:hover {
    border-color: var(--green, #6BE03F);
    color: var(--green, #6BE03F);
  }

  .filter-btn.active {
    background: var(--green, #6BE03F);
    border-color: var(--green, #6BE03F);
    color: var(--white, #fff);
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .product-card {
    background: var(--white, #fff);
    border: 1px solid var(--border, #E5E7EB);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .product-card.hidden { display: none; }

  .product-card:hover {
    border-color: var(--green, #6BE03F);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    transform: translateY(-4px);
  }

  .card-img {
    position: relative;
    background: var(--gray-100, #F5F6F8);
    padding: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 200px;
  }

  .card-img img {
    max-width: 80%;
    max-height: 160px;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .product-card:hover .card-img img {
    transform: scale(1.06);
  }

  .voltage-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    padding: 4px 10px;
    background: var(--dark, #1A1A1A);
    color: var(--green, #6BE03F);
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 11px;
    border-radius: 4px;
  }

  .card-body {
    padding: 20px;
  }

  .card-category {
    font-size: 11px;
    color: var(--gray-500, #7A7A7A);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .card-title {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: var(--dark, #1A1A1A);
    margin: 4px 0 8px;
  }

  .card-desc {
    font-size: 13px;
    line-height: 1.5;
    color: var(--gray-500, #7A7A7A);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-specs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  .spec {
    font-size: 11px;
    color: var(--gray-700, #4A4A4A);
    background: var(--gray-100, #F5F6F8);
    padding: 3px 8px;
    border-radius: 4px;
  }

  .spec strong {
    color: var(--dark, #1A1A1A);
  }

  .card-footer {
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid var(--border, #E5E7EB);
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--green, #6BE03F);
    font-family: 'GeneralSans-Semibold', sans-serif;
    font-weight: 600;
    font-size: 13px;
    transition: gap 0.25s ease;
  }

  .product-card:hover .card-link { gap: 10px; }

  .no-results {
    text-align: center;
    padding: 80px 0;
  }

  .no-results h3 {
    margin-bottom: 8px;
    color: var(--dark, #1A1A1A);
  }

  .no-results p {
    color: var(--gray-500, #7A7A7A);
  }

  /* V-PACK CTA */
  .vpack-cta {
    padding: 0 0 80px;
  }

  .cta-card {
    background: linear-gradient(135deg, var(--dark, #1A1A1A) 0%, #2d2d2d 100%);
    border-radius: 16px;
    padding: 56px;
    text-align: center;
  }

  .cta-card .section-tag {
    background: rgba(107, 224, 63, 0.15);
  }

  .cta-card h2 {
    color: var(--white, #fff);
    margin-bottom: 12px;
  }

  .cta-card p {
    color: rgba(255,255,255,0.7);
    font-size: 16px;
    line-height: 1.7;
    max-width: 520px;
    margin: 0 auto 24px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: var(--green, #6BE03F);
    color: var(--white, #fff);
    text-decoration: none;
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.5px;
    border-radius: 8px;
    border: 2px solid var(--green, #6BE03F);
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    background: var(--white, #fff);
    color: var(--dark, #1A1A1A);
    border-color: var(--white, #fff);
    transform: translateY(-2px);
  }

  /* FOOTER */
  .site-footer {
    background: var(--dark, #1A1A1A);
    padding: 64px 0 32px;
    color: #fff;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .footer-logo { height: 48px; width: auto; display: block; margin-bottom: 16px; }
  .footer-brand p { font-size: 14px; line-height: 1.7; color: rgba(255,255,255,0.6); }

  .footer-links h4,
  .footer-contact-col h4 {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-size: 14px;
    color: var(--green, #6BE03F);
    margin-bottom: 16px;
  }

  .footer-links a,
  .footer-contact-col a {
    display: block;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-size: 14px;
    padding: 4px 0;
    transition: color 0.25s ease;
  }

  .footer-links a:hover,
  .footer-contact-col a:hover { color: var(--green, #6BE03F); }

  .footer-contact-col p {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255,255,255,0.6);
    margin-bottom: 12px;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
  }

  .footer-bottom p { font-size: 13px; color: rgba(255,255,255,0.4); }

  .footer-social { display: flex; gap: 12px; }

  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(255,255,255,0.08);
    border-radius: 50%;
    color: rgba(255,255,255,0.6);
    transition: all 0.25s ease;
  }

  .footer-social a:hover {
    background: var(--green, #6BE03F);
    color: var(--dark, #1A1A1A);
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .products-grid { grid-template-columns: repeat(3, 1fr); }
    .footer-grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
  }

  @media (max-width: 768px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .card-img { height: 160px; padding: 16px; }
    .card-specs { display: none; }
    .cta-card { padding: 32px 24px; }
    .footer-grid { grid-template-columns: 1fr; text-align: center; }
    .footer-bottom { flex-direction: column; gap: 16px; text-align: center; }
    .footer-social { justify-content: center; }
  }

  @media (max-width: 480px) {
    .products-grid { grid-template-columns: 1fr; }
    .filter-bar { gap: 8px; }
    .filter-btn { padding: 6px 14px; font-size: 12px; }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.product-card');
  const noResults = document.getElementById('noResults');

  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filterBtns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');

      const filter = btn.getAttribute('data-filter');
      let visible = 0;

      cards.forEach(function(card) {
        const category = card.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          card.classList.remove('hidden');
          card.style.display = '';
          visible++;
        } else {
          card.classList.add('hidden');
          card.style.display = 'none';
        }
      });

      noResults.style.display = visible === 0 ? 'block' : 'none';
    });
  });
});
</script>
