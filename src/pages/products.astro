---
import Layout from '@/layouts/Layout.astro';
import productsData from '@/data/products.json';

const categories = [
  { key: 'all', label: 'Tüm Ürünler' },
  { key: 'drill', label: 'Matkaplar' },
  { key: 'driver', label: 'Vidalama' },
  { key: 'grinder', label: 'Taşlama' },
  { key: 'hammer', label: 'Kırıcı Delici' },
  { key: 'battery', label: 'Batarya' },
  { key: 'charger', label: 'Şarj Cihazı' },
  { key: 'storage', label: 'Taşıma' },
  { key: 'set', label: 'Setler' },
];
---

<Layout 
  title="Ürünler - Voltz Power Tools | Akülü El Aletleri Kataloğu"
  description="Voltz Power Tools tam ürün kataloğu. Brushless motor teknolojili akülü matkaplar, tornavidalar, taşlama makineleri, V-PACK batarya sistemi."
  keywords="voltz ürünler, akülü matkap, akülü tornavida, akülü taşlama, v-pack batarya, brushless motor"
>

  <section class="page-hero">
    <div class="hero-bg-overlay"></div>
    <div class="container">
      <div class="page-hero-inner">
        <h1>ÜRÜNLERİMİZ</h1>
        <p>Profesyonel işlerinizi bir üst seviyeye taşıyacak premium el aletleri.</p>
      </div>
    </div>
  </section>

  <section class="products-section">
    <div class="container">
      <div class="products-layout">

        <aside class="sidebar" id="sidebar">
          <nav class="sidebar-nav">
            {categories.map((cat) => (
              <button 
                class={`sidebar-link ${cat.key === 'all' ? 'active' : ''}`} 
                data-filter={cat.key}
              >
                {cat.label}
                {cat.key !== 'all' && <span class="sidebar-count" data-count={cat.key}></span>}
              </button>
            ))}
          </nav>
        </aside>

        <div class="products-main">
          <div class="products-topbar">
            <p class="products-count" id="productsCount"></p>
          </div>

          <div class="products-grid" id="productsGrid">
            {productsData.map((product) => (
              <div class="product-card" data-category={product.category}>
                <a href={`/products/${product.id}`} class="card-main">
                  <div class="card-img">
                    <img src={product.image} alt={product.title} loading="lazy" />
                  </div>
                  <div class="card-body">
                    <h3 class="card-title">{product.title}</h3>
                    <span class="card-sub">{product.subcategory}</span>
                  </div>
                </a>
                <div class="card-actions">
                  <a href={`/products/${product.id}`} class="card-specs">
                    ÜRÜN DETAYLARI
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                  </a>
                  <div class="card-buy">
                    <span class="buy-label">SATIN AL</span>
                    <div class="buy-links">
                      <a href={`https://www.hepsiburada.com/ara?q=Voltz+${product.title}`} target="_blank" rel="noopener noreferrer" class="buy-link buy-hb">hepsiburada</a>
                      <a href={`https://www.trendyol.com/sr?q=Voltz+${product.title}`} target="_blank" rel="noopener noreferrer" class="buy-link buy-ty">trendyol</a>
                      <a href={`https://www.amazon.com.tr/s?k=Voltz+${product.title}`} target="_blank" rel="noopener noreferrer" class="buy-link buy-az">amazon</a>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="no-results" id="noResults" style="display:none">
            <h3>ÜRÜN BULUNAMADI</h3>
            <p>Bu kategoride henüz ürün bulunmuyor.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand"><img src="/img/logo/voltz-symbol-green.png" alt="Voltz" class="footer-logo"><p>Profesyonel el aletlerinde güvenin adresi.</p></div>
        <div class="footer-links"><h4>Sayfalar</h4><a href="/">Anasayfa</a><a href="/about">Hakkımızda</a><a href="/products">Ürünlerimiz</a><a href="/contact">İletişim</a></div>
        <div class="footer-links"><h4>Ürünler</h4><a href="/products">Matkaplar</a><a href="/products">Tornavidalar</a><a href="/products">Taşlama</a><a href="/v-pack">V-PACK</a></div>
        <div class="footer-contact-col"><h4>İletişim</h4><p>Teknoloji Caddesi No: 123<br>Sanayi Mahallesi, İstanbul</p><a href="mailto:info@voltzpowertools.com">info@voltzpowertools.com</a><a href="tel:+902123456789">+90 212 345 67 89</a></div>
      </div>
      <div class="footer-bottom">
      <p>&copy; 2025 Voltz Power Tools. Tüm hakları saklıdır.</p>
      <div class="footer-social">
        <a href="#" aria-label="LinkedIn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="#" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
      </div>
    </div>
    </div>
  </footer>

</Layout>

<style is:global>
  :root {
    --green: #6BE03F;
    --green-dark: #5BC935;
    --dark: #1A1A1A;
    --darker: #111111;
    --gray-900: #2D2D2D;
    --gray-700: #4A4A4A;
    --gray-500: #7A7A7A;
    --gray-100: #F5F6F8;
    --white: #FFFFFF;
    --border: #E5E7EB;
  }

  /* ── HERO ── */
  .page-hero {
    position: relative;
    padding: 80px 0 60px;
    background: var(--dark);
    clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%);
    text-align: center;
    overflow: hidden;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: url('/voltzgorseller/03.png') center / cover no-repeat;
    opacity: 0.12;
    pointer-events: none;
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
  }

  .page-hero h1 {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: clamp(32px, 5vw, 48px);
    color: var(--white);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .page-hero p {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.5);
  }

  /* ── LAYOUT ── */
  .products-section {
    padding: 48px 0 80px;
  }

  .products-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 40px;
    align-items: start;
  }

  /* ── SIDEBAR ── */
  .sidebar {
    position: sticky;
    top: 100px;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid var(--border);
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0;
    border: none;
    border-top: 1px solid var(--border);
    background: none;
    cursor: pointer;
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--gray-700);
    text-align: left;
    transition: color 0.2s ease;
  }

  .sidebar-link:hover {
    color: var(--dark);
  }

  .sidebar-link.active {
    color: var(--green);
    border-left: 3px solid var(--green);
    padding-left: 12px;
    margin-left: -1px;
  }

  .sidebar-count {
    font-size: 12px;
    color: var(--gray-500);
    font-weight: 600;
  }

  /* ── TOPBAR ── */
  .products-topbar {
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .products-count {
    font-size: 13px;
    color: var(--gray-500);
    font-family: 'GeneralSans-Regular', sans-serif;
  }

  /* ── GRID ── */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ── CARD ── */
  .product-card {
    background: var(--white);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .product-card.hidden { display: none; }

  .product-card:hover {
    border-color: var(--green);
  }

  .card-main {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-img {
    background: var(--gray-100);
    padding: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 220px;
  }

  .card-img img {
    max-width: 75%;
    max-height: 180px;
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  .product-card:hover .card-img img {
    transform: scale(1.05);
  }

  .card-body {
    padding: 16px 20px 12px;
  }

  .card-title {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 15px;
    color: var(--dark);
    text-transform: uppercase;
    letter-spacing: 0.3px;
    margin-bottom: 4px;
  }

  .card-sub {
    display: block;
    font-size: 12px;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* ── CARD ACTIONS ── */
  .card-actions {
    padding: 0 20px 16px;
  }

  .card-specs {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    background: var(--green);
    color: var(--dark);
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 6px), calc(100% - 6px) 100%, 0 100%);
    transition: background 0.2s ease;
  }

  .card-specs:hover {
    background: var(--green-dark);
  }

  .card-buy {
    margin-top: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .buy-label {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 9px;
    letter-spacing: 1px;
    color: var(--gray-500);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .buy-links {
    display: flex;
    gap: 6px;
  }

  .buy-link {
    padding: 4px 8px;
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 800;
    font-size: 9px;
    text-decoration: none;
    border: 1px solid var(--border);
    transition: all 0.2s ease;
  }

  .buy-hb { color: #FF6000; }
  .buy-hb:hover { background: #FF6000; color: #fff; border-color: #FF6000; }
  .buy-ty { color: #F27A1A; }
  .buy-ty:hover { background: #F27A1A; color: #fff; border-color: #F27A1A; }
  .buy-az { color: #232F3E; }
  .buy-az:hover { background: #FF9900; color: #232F3E; border-color: #FF9900; }

  /* ── NO RESULTS ── */
  .no-results {
    text-align: center;
    padding: 80px 20px;
  }

  .no-results h3 {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-size: 20px;
    color: var(--dark);
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  .no-results p {
    color: var(--gray-500);
  }

  /* ── FOOTER ── */
  .site-footer { background: var(--darker, #111); padding: 64px 0 32px; color: #fff; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 48px; padding-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .footer-logo { height: 48px; width: auto; display: block; margin-bottom: 16px; }
  .footer-brand p { font-size: 14px; line-height: 1.7; color: rgba(255,255,255,0.5); }
  .footer-links h4, .footer-contact-col h4 { font-family: 'GeneralSans-Bold', sans-serif; font-size: 13px; color: var(--green, #6BE03F); margin-bottom: 16px; letter-spacing: 1px; text-transform: uppercase; }
  .footer-links a, .footer-contact-col a { display: block; color: rgba(255,255,255,0.5); text-decoration: none; font-size: 14px; padding: 4px 0; transition: color 0.2s; }
  .footer-links a:hover, .footer-contact-col a:hover { color: var(--green, #6BE03F); }
  .footer-contact-col p { font-size: 14px; line-height: 1.6; color: rgba(255,255,255,0.5); margin-bottom: 12px; }
  .footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 24px; }
  .footer-bottom p { font-size: 13px; color: rgba(255,255,255,0.3); }
  .footer-social { display: flex; gap: 8px; }
  .footer-social a { display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.5); font-size: 12px; font-weight: 700; text-decoration: none; transition: all 0.2s; }
  .footer-social a:hover { background: var(--green, #6BE03F); color: var(--dark, #1A1A1A); }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .products-layout {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .sidebar {
      position: static;
    }

    .sidebar-nav {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0;
      border-bottom: none;
    }

    .sidebar-link {
      border-top: none;
      padding: 8px 14px;
      font-size: 12px;
      border: 1px solid var(--border);
      margin: 0 4px 4px 0;
    }

    .sidebar-link.active {
      border-left: 1px solid var(--green);
      padding-left: 14px;
      margin-left: 0;
      background: rgba(107,224,63,0.08);
      border-color: var(--green);
    }

    .sidebar-count { display: none; }

    .products-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .card-img { height: 180px; padding: 16px; }
    .card-img img { max-height: 150px; }
    .footer-grid { grid-template-columns: 1fr; text-align: center; gap: 32px; }
    .footer-brand .footer-logo { margin: 0 auto 16px; }
    .footer-brand p { max-width: 100%; margin: 0 auto; }
    .footer-bottom { flex-direction: column; gap: 16px; text-align: center; }
    .footer-social { justify-content: center; }
    .footer-social a { width: 40px; height: 40px; }
  }

  @media (max-width: 480px) {
    .products-grid { grid-template-columns: 1fr; }
    .buy-links { flex-wrap: wrap; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.product-card') as NodeListOf<HTMLElement>;
    const buttons = document.querySelectorAll('.sidebar-link') as NodeListOf<HTMLButtonElement>;
    const countEl = document.getElementById('productsCount');
    const noResults = document.getElementById('noResults');
    const grid = document.getElementById('productsGrid');

    function getCounts(): Record<string, number> {
      const counts: Record<string, number> = {};
      cards.forEach((card) => {
        const cat = card.dataset.category || '';
        counts[cat] = (counts[cat] || 0) + 1;
      });
      return counts;
    }

    const counts = getCounts();
    document.querySelectorAll('.sidebar-count').forEach((el) => {
      const key = (el as HTMLElement).dataset.count || '';
      el.textContent = `(${counts[key] || 0})`;
    });

    function filterProducts(category: string) {
      let visible = 0;
      cards.forEach((card) => {
        if (category === 'all' || card.dataset.category === category) {
          card.classList.remove('hidden');
          visible++;
        } else {
          card.classList.add('hidden');
        }
      });

      if (countEl) {
        const label = category === 'all' ? 'Tüm Ürünler' : buttons[Array.from(buttons).findIndex(b => b.dataset.filter === category)]?.textContent?.trim() || '';
        countEl.textContent = `${label} — ${visible} ürün`;
      }

      if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
      if (grid) grid.style.display = visible === 0 ? 'none' : '';
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        filterProducts(btn.dataset.filter || 'all');
      });
    });

    filterProducts('all');
  });
</script>
