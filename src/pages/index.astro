---
import Layout from '@/layouts/Layout.astro';
import productsData from '@/data/products.json';

const tools = productsData.filter(p => !['battery', 'charger', 'storage'].includes(p.category));
const featuredProducts = productsData.slice(0, 8);
---

<Layout 
  title="Voltz Power Tools - Profesyonel Akülü El Aletleri | Brushless Motor Teknolojisi"
  description="Voltz Power Tools ile profesyonel işleriniz için güçlü brushless motor teknolojili akülü el aletleri. Matkap, tornavida, taşlama makinesi ve V-PACK batarya sistemi."
  keywords="voltz power tools, akülü matkap, brushless motor, akülü alet, profesyonel alet, v-pack batarya"
>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <span class="hero-badge">BRUSHLESS MOTOR TEKNOLOJİSİ</span>
          <h1>Geleceği <span class="text-green">Şekillendiren</span> Güç</h1>
          <p class="hero-desc">
            Her zorlu görevin üstesinden gelecek güç, dayanıklılık ve yenilikçi 
            performans — profesyonellerin beklentilerini aşan el aletleri.
          </p>
          <div class="hero-actions">
            <a href="/products" class="btn-primary">
              ÜRÜNLERİ KEŞFET
              <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </a>
            <a href="/pdf/voltz-katalog.pdf" download="Voltz-Katalog.pdf" class="btn-outline">
              KATALOG İNDİR
              <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 3v8M5 8l3 3 3-3M3 13h10"/></svg>
            </a>
          </div>
          <div class="hero-stats">
            <div class="stat">
              <span class="stat-value">20V</span>
              <span class="stat-label">Max Voltaj</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-value">500 N.m</span>
              <span class="stat-label">Max Tork</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-value">13+</span>
              <span class="stat-label">Ürün</span>
            </div>
          </div>
        </div>
        <div class="hero-image">
          <div class="hero-image-bg"></div>
          <img src="/img/products/tools/thumbs/vzdr-201.png" alt="Voltz VZDR-201 Darbeli Matkap" class="hero-product-img">
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section class="products-section">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">ÜRÜNLERİMİZ</div>
        <h2>Profesyonel El Aletleri</h2>
        <p class="section-desc">Endüstriyel ve inşaat profesyonelleri için tasarlanmış, brushless motor teknolojili akülü aletler.</p>
      </div>
      <div class="products-grid">
        {featuredProducts.map((product) => (
          <a href={`/products/${product.id}`} class="product-card">
            <div class="product-card-img">
              <img src={product.image} alt={product.title} loading="lazy">
              {product.voltage && (
                <span class="voltage-badge">{product.voltage}</span>
              )}
            </div>
            <div class="product-card-body">
              <span class="product-card-category">{product.subcategory}</span>
              <h3 class="product-card-title">{product.title}</h3>
              <div class="product-card-footer">
                <span class="product-card-link">
                  Detaylar
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
      <div class="products-cta">
        <a href="/products" class="btn-outline">
          TÜM ÜRÜNLERİ GÖR
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- TECHNOLOGY -->
  <section class="tech-section">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">TEKNOLOJİ</div>
        <h2>Neden <span class="text-green">Voltz</span>?</h2>
      </div>
      <div class="tech-grid">
        <div class="tech-card">
          <div class="tech-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3>Brushless Motor</h3>
          <p>Kömürsüz motor teknolojisi ile %30 daha uzun ömür, daha yüksek verimlilik ve bakım gerektirmeyen performans.</p>
        </div>
        <div class="tech-card">
          <div class="tech-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round"><rect x="6" y="7" width="12" height="13" rx="1"/><path d="M9 7V5a3 3 0 0 1 6 0v2"/><path d="M10 12h4M12 12v3"/></svg>
          </div>
          <h3>V-PACK Sistem</h3>
          <p>20V ve 16.8V seçenekleriyle tüm aletleriniz için ortak batarya platformu. Tek şarj, çoklu kullanım.</p>
        </div>
        <div class="tech-card">
          <div class="tech-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Dayanıklı Yapı</h3>
          <p>Endüstriyel şantiye koşullarına dayanıklı, metal mandren ve ergonomik kavrama ile profesyonel kullanım.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-content">
          <div class="section-tag">HAKKIMIZDA</div>
          <h2>Her İşe, Her İhtiyaca Güçlü <span class="text-green">Çözümler</span></h2>
          <p>
            Voltz, yoğun ve sürekli kullanım gerektiren endüstriyel ve inşaat 
            profesyonelleri için özel olarak tasarlanmış bir alet markasıdır. 
            Güvenlik, güvenilirlik, yüksek kalite ve üstün performans ilkelerine 
            sadık kalarak profesyonellerin işini kolaylaştırıyoruz.
          </p>
          <p>
            Yenilikçi ürün tasarımı, titiz kalite kontrolü ve samimi hizmet 
            anlayışı sayesinde profesyonel kullanıcıların takdirini ve güvenini 
            kazanmayı hedefliyoruz.
          </p>
          <a href="/about" class="btn-outline">
            DAHA FAZLA
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        </div>
        <div class="about-image">
          <img src="/img/hero/hero-slider01.jpg" alt="Voltz Power Tools">
        </div>
      </div>
    </div>
  </section>

  <!-- CATALOG CTA -->
  <section id="katalog" class="catalog-section">
    <div class="container">
      <div class="catalog-card">
        <div class="catalog-content">
          <h2>Ürün Kataloğu</h2>
          <p>Tüm ürünlerimizin teknik detaylarını, özelliklerini ve aksesuarlarını içeren kapsamlı kataloğumuzu indirin.</p>
          <a href="/pdf/voltz-katalog.pdf" download="Voltz-Katalog.pdf" class="btn-primary">
            KATALOG İNDİR
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 3v8M5 8l3 3 3-3M3 13h10"/></svg>
          </a>
        </div>
        <div class="catalog-visual">
          <div class="catalog-icon">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.5" stroke-linecap="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <img src="/img/logo/footer-logo.svg" alt="Voltz Power Tools" class="footer-logo">
          <p>Profesyonel el aletlerinde güvenin adresi. Brushless motor teknolojisi ile gücü ve dayanıklılığı birleştiriyoruz.</p>
        </div>
        <div class="footer-links">
          <h4>Sayfalar</h4>
          <a href="/">Anasayfa</a>
          <a href="/about">Hakkımızda</a>
          <a href="/products">Ürünlerimiz</a>
          <a href="/contact">İletişim</a>
        </div>
        <div class="footer-links">
          <h4>Ürünler</h4>
          <a href="/products">Matkaplar</a>
          <a href="/products">Tornavidalar</a>
          <a href="/products">Taşlama</a>
          <a href="/v-pack">V-PACK Sistem</a>
        </div>
        <div class="footer-contact">
          <h4>İletişim</h4>
          <p>Teknoloji Caddesi No: 123<br>Sanayi Mahallesi, İstanbul</p>
          <a href="mailto:info@voltzpowertools.com">info@voltzpowertools.com</a>
          <a href="tel:+902123456789">+90 212 345 67 89</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2025 Voltz Power Tools. Tüm hakları saklıdır.</p>
        <div class="footer-social">
          <a href="#" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="#" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </footer>

</Layout>

<style>
  /* ========== HERO ========== */
  .hero {
    padding: 60px 0 80px;
    background: linear-gradient(135deg, var(--white) 0%, var(--gray-50) 100%);
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    min-height: 520px;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    padding: 6px 16px;
    background: rgba(107, 224, 63, 0.1);
    color: var(--green-dark);
    font-family: 'GeneralSans-Semibold', sans-serif;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 1.5px;
    border-radius: 100px;
    width: fit-content;
    border: 1px solid rgba(107, 224, 63, 0.2);
  }

  .text-green { color: var(--green); }

  .hero-desc {
    font-size: 18px;
    line-height: 1.7;
    color: var(--gray-700);
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: var(--green);
    color: var(--white);
    text-decoration: none;
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.5px;
    border-radius: var(--radius-sm);
    transition: all var(--transition);
    border: 2px solid var(--green);
  }

  .btn-primary:hover {
    background: var(--dark);
    border-color: var(--dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: transparent;
    color: var(--dark);
    text-decoration: none;
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.5px;
    border-radius: var(--radius-sm);
    border: 2px solid var(--border);
    transition: all var(--transition);
  }

  .btn-outline:hover {
    border-color: var(--green);
    color: var(--green);
    transform: translateY(-2px);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    margin-top: 8px;
  }

  .stat { display: flex; flex-direction: column; gap: 4px; }
  .stat-value {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 24px;
    color: var(--dark);
  }
  .stat-label {
    font-size: 13px;
    color: var(--gray-500);
  }
  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }

  .hero-image {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
  }

  .hero-image-bg {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(107,224,63,0.08) 0%, transparent 70%);
  }

  .hero-product-img {
    position: relative;
    z-index: 2;
    max-width: 100%;
    max-height: 420px;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.15));
    transition: transform 0.5s ease;
  }

  .hero-image:hover .hero-product-img {
    transform: scale(1.03) rotate(-1deg);
  }

  /* ========== SECTION HEADER ========== */
  .section-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-tag {
    display: inline-block;
    padding: 4px 14px;
    background: rgba(107, 224, 63, 0.1);
    color: var(--green-dark);
    font-family: 'GeneralSans-Semibold', sans-serif;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 1.5px;
    border-radius: 100px;
    margin-bottom: 16px;
  }

  .section-desc {
    font-size: 17px;
    line-height: 1.6;
    color: var(--gray-500);
    max-width: 560px;
    margin: 12px auto 0;
  }

  /* ========== PRODUCTS GRID ========== */
  .products-section {
    padding: 100px 0;
    background: var(--white);
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .product-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    transition: all var(--transition);
  }

  .product-card:hover {
    border-color: var(--green);
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .product-card-img {
    position: relative;
    background: var(--gray-100);
    padding: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 200px;
    overflow: hidden;
  }

  .product-card-img img {
    max-width: 80%;
    max-height: 160px;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .product-card:hover .product-card-img img {
    transform: scale(1.08);
  }

  .voltage-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    padding: 4px 10px;
    background: var(--dark);
    color: var(--green);
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.5px;
    border-radius: 4px;
  }

  .product-card-body {
    padding: 20px;
  }

  .product-card-category {
    font-size: 12px;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .product-card-title {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: var(--dark);
    margin-top: 4px;
  }

  .product-card-footer {
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }

  .product-card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--green);
    font-family: 'GeneralSans-Semibold', sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.3px;
    transition: gap var(--transition);
  }

  .product-card:hover .product-card-link { gap: 10px; }

  .products-cta {
    text-align: center;
    margin-top: 48px;
  }

  /* ========== TECH SECTION ========== */
  .tech-section {
    padding: 100px 0;
    background: var(--gray-100);
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .tech-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 40px 32px;
    transition: all var(--transition);
  }

  .tech-card:hover {
    border-color: var(--green);
    box-shadow: var(--shadow-green);
    transform: translateY(-4px);
  }

  .tech-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(107, 224, 63, 0.1);
    border-radius: var(--radius-md);
    margin-bottom: 24px;
  }

  .tech-card h3 {
    margin-bottom: 12px;
  }

  .tech-card p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--gray-500);
  }

  /* ========== ABOUT ========== */
  .about-section {
    padding: 100px 0;
    background: var(--white);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .about-content p {
    font-size: 16px;
    line-height: 1.8;
    color: var(--gray-700);
  }

  .about-content .btn-outline {
    width: fit-content;
    margin-top: 8px;
  }

  .about-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .about-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .about-image:hover img { transform: scale(1.03); }

  /* ========== CATALOG ========== */
  .catalog-section {
    padding: 80px 0 100px;
    background: var(--gray-100);
  }

  .catalog-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 48px 56px;
    gap: 40px;
  }

  .catalog-content h2 {
    margin-bottom: 12px;
  }

  .catalog-content p {
    font-size: 16px;
