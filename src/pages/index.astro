---
import Layout from '@/layouts/Layout.astro';
import productsData from '@/data/products.json';
const tools = productsData.filter(p => !['battery', 'charger', 'storage'].includes(p.category));
const featuredProducts = productsData.slice(0, 8);
---

<Layout 
  title="Voltz Power Tools - Profesyonel Akülü El Aletleri | Brushless Motor Teknolojisi"
  description="Voltz Power Tools ile profesyonel işleriniz için güçlü brushless motor teknolojili akülü el aletleri. Matkap, tornavida, taşlama makinesi ve V-PACK batarya sistemi."
  keywords="voltz power tools, akülü matkap, brushless motor, akülü alet, profesyonel alet, v-pack batarya"
>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/voltzgorseller/01.png" alt="Voltz Power Tools Ürün Ailesi" class="hero-bg-img" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="hero-label">BRUSHLESS MOTOR TEKNOLOJİSİ</span>
        <h1 class="hero-title">GELECEĞİ<br/>ŞEKİLLENDİREN<br/>GÜÇ</h1>
        <p class="hero-desc">
          Her zorlu görevin üstesinden gelecek güç, dayanıklılık ve yenilikçi 
          performans — profesyonellerin beklentilerini aşan el aletleri.
        </p>
        <div class="hero-actions">
          <a href="/products" class="btn-angular btn-green">
            ÜRÜNLERİ KEŞFET
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
          <a href="/v-pack" class="btn-angular btn-dark-solid">
            V-PACK SİSTEM
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section class="products-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">ÜRÜNLERİMİZ</h2>
        <div class="section-accent"></div>
      </div>
      <div class="products-grid">
        {featuredProducts.map((product) => (
          <div class="product-card">
            <a href={`/products/${product.id}`} class="product-card-main">
              <div class="product-card-img">
                <img src={product.image} alt={product.title} loading="lazy" />
                {product.voltage && (
                  <span class="voltage-badge">{product.voltage}</span>
                )}
              </div>
              <div class="product-card-body">
                <h3 class="product-card-title">{product.title}</h3>
                <span class="product-card-model">{product.subcategory}</span>
                <span class="product-card-link">
                  DETAYLAR
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                </span>
              </div>
            </a>
            <div class="product-card-mp">
              <a href={`https://www.hepsiburada.com/ara?q=Voltz+${product.title}`} target="_blank" rel="noopener noreferrer" class="pmp pmp-hb" title="Hepsiburada">hepsiburada</a>
              <a href={`https://www.trendyol.com/sr?q=Voltz+${product.title}`} target="_blank" rel="noopener noreferrer" class="pmp pmp-ty" title="Trendyol">trendyol</a>
              <a href={`https://www.amazon.com.tr/s?k=Voltz+${product.title}`} target="_blank" rel="noopener noreferrer" class="pmp pmp-az" title="Amazon">amazon</a>
            </div>
          </div>
        ))}
      </div>
      <div class="products-cta">
        <a href="/products" class="btn-angular btn-green">
          TÜM ÜRÜNLERİ GÖR
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- TECHNOLOGY -->
  <section class="tech-section">
    <div class="container">
      <div class="section-header section-header--light">
        <span class="tech-label">TEKNOLOJİ</span>
        <h2 class="section-title section-title--white">NEDEN <span class="text-green">VOLTZ</span>?</h2>
      </div>
      <div class="tech-grid">
        <div class="tech-card">
          <div class="tech-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="square">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <h3>BRUSHLESS MOTOR</h3>
          <p>Kömürsüz motor teknolojisi ile %30 daha uzun ömür, daha yüksek verimlilik ve bakım gerektirmeyen performans.</p>
        </div>
        <div class="tech-card">
          <div class="tech-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="square">
              <rect x="6" y="7" width="12" height="13"/><path d="M9 7V5a3 3 0 0 1 6 0v2"/><path d="M10 12h4M12 12v3"/>
            </svg>
          </div>
          <h3>V-PACK SİSTEM</h3>
          <p>20V ve 16.8V seçenekleriyle tüm aletleriniz için ortak batarya platformu. Tek şarj, çoklu kullanım.</p>
        </div>
        <div class="tech-card">
          <div class="tech-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="square">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>DAYANIKLI YAPI</h3>
          <p>Endüstriyel şantiye koşullarına dayanıklı, metal mandren ve ergonomik kavrama ile profesyonel kullanım.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-content">
          <span class="about-label">HAKKIMIZDA</span>
          <h2 class="about-title">HER İŞE, HER İHTİYACA GÜÇLÜ <span class="text-green">ÇÖZÜMLER</span></h2>
          <p>
            Voltz, yoğun ve sürekli kullanım gerektiren endüstriyel ve inşaat 
            profesyonelleri için özel olarak tasarlanmış bir alet markasıdır. 
            Güvenlik, güvenilirlik, yüksek kalite ve üstün performans ilkelerine 
            sadık kalarak profesyonellerin işini kolaylaştırıyoruz.
          </p>
          <p>
            Yenilikçi ürün tasarımı, titiz kalite kontrolü ve samimi hizmet 
            anlayışı sayesinde profesyonel kullanıcıların takdirini ve güvenini 
            kazanmayı hedefliyoruz.
          </p>
          <a href="/about" class="btn-angular btn-green">
            DAHA FAZLA
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        </div>
        <div class="about-image">
          <img src="/voltzgorseller/03.png" alt="Voltz Power Tools" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA SHOWCASE -->
  <section class="showcase-cta">
    <div class="showcase-bg">
      <img src="/img/products/voltz-lineup.jpeg" alt="Voltz Power Tools" />
      <div class="showcase-overlay"></div>
    </div>
    <div class="container showcase-inner">
      <span class="showcase-tag">VOLTZ POWER TOOLS</span>
      <h2 class="showcase-title">PROFESYONEL İŞLER İÇİN<br/><span class="text-green">PROFESYONEL ALETLER</span></h2>
      <p class="showcase-desc">13'ten fazla ürünle tam ekosistem. Brushless motor teknolojisi, V-PACK batarya platformu ve endüstriyel dayanıklılık.</p>
      <div class="showcase-actions">
        <a href="/products" class="btn-angular btn-green">
          ÜRÜNLERİ KEŞFET
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
        <a href="/contact" class="btn-angular btn-dark-solid">
          İLETİŞİME GEÇİN
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <img src="/img/logo/voltz-symbol-green.png" alt="Voltz Power Tools" class="footer-logo" />
          <p>Profesyonel el aletlerinde güvenin adresi. Brushless motor teknolojisi ile gücü ve dayanıklılığı birleştiriyoruz.</p>
        </div>
        <div class="footer-links">
          <h4>SAYFALAR</h4>
          <a href="/">Anasayfa</a>
          <a href="/about">Hakkımızda</a>
          <a href="/products">Ürünlerimiz</a>
          <a href="/contact">İletişim</a>
        </div>
        <div class="footer-links">
          <h4>ÜRÜNLER</h4>
          <a href="/products">Matkaplar</a>
          <a href="/products">Tornavidalar</a>
          <a href="/products">Taşlama</a>
          <a href="/v-pack">V-PACK Sistem</a>
        </div>
        <div class="footer-contact">
          <h4>İLETİŞİM</h4>
          <p>Teknoloji Caddesi No: 123<br/>Sanayi Mahallesi, İstanbul</p>
          <a href="mailto:info@voltzpowertools.com">info@voltzpowertools.com</a>
          <a href="tel:+902123456789">+90 212 345 67 89</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2025 Voltz Power Tools. Tüm hakları saklıdır.</p>
        <div class="footer-social">
          <a href="#" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="#" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </footer>

</Layout>

<style>
  /* ========== ANGULAR BUTTONS ========== */
  .btn-angular {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    text-decoration: none;
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: all var(--transition);
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%);
  }

  .btn-green {
    background: var(--green);
    color: #111111;
  }

  .btn-green:hover {
    background: #5BC935;
    transform: translateY(-2px);
  }

  .btn-border {
    background: transparent;
    color: var(--white);
    border: 2px solid var(--white);
    clip-path: none;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%);
    position: relative;
  }

  .btn-border::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 2px solid var(--white);
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%);
    pointer-events: none;
  }

  .btn-border:hover {
    background: rgba(255,255,255,0.1);
    transform: translateY(-2px);
  }

  .btn-dark {
    background: #111111;
    color: var(--white);
  }

  .btn-dark:hover {
    background: #000000;
    transform: translateY(-2px);
  }

  .text-green { color: var(--green); }

  /* ========== HERO ========== */
  .hero {
    position: relative;
    min-height: 650px;
    display: flex;
    align-items: center;
    overflow: hidden;
    clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(0,0,0,0.92) 0%,
      rgba(0,0,0,0.7) 40%,
      rgba(0,0,0,0.2) 70%,
      transparent 100%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    padding: 100px 24px 140px;
  }

  .hero-content {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .hero-label {
    display: inline-block;
    padding: 8px 16px;
    background: rgba(107, 224, 63, 0.15);
    color: var(--green);
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 2px;
    width: fit-content;
    border-left: 3px solid var(--green);
  }

  .hero-title {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: clamp(42px, 6vw, 72px);
    line-height: 1.0;
    color: var(--white);
    letter-spacing: -1px;
    text-transform: uppercase;
  }

  .hero-desc {
    font-size: 17px;
    line-height: 1.7;
    color: rgba(255,255,255,0.7);
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    padding-top: 8px;
  }

  /* ========== PRODUCTS ========== */
  .products-section {
    padding: 100px 0;
    background: var(--white);
  }

  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .section-header--light {
    text-align: center;
  }

  .section-title {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: clamp(28px, 3.5vw, 42px);
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--dark);
  }

  .section-title--white {
    color: var(--white);
  }

  .section-accent {
    width: 60px;
    height: 4px;
    background: var(--green);
    margin: 16px auto 0;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .product-card {
    background: var(--white);
    border: 1px solid var(--border);
    overflow: hidden;
    text-decoration: none;
    transition: all var(--transition);
    position: relative;
    border-left: 4px solid transparent;
  }

  .product-card:hover {
    border-left-color: var(--green);
    transform: translateY(-6px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.1);
  }

  .product-card-img {
    position: relative;
    background: #F5F6F8;
    padding: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 200px;
    overflow: hidden;
  }

  .product-card-img img {
    max-width: 80%;
    max-height: 160px;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .product-card:hover .product-card-img img {
    transform: scale(1.08);
  }

  .voltage-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    padding: 4px 10px;
    background: var(--dark);
    color: var(--green);
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1px;
  }

  .product-card-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .product-card-title {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: var(--dark);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .product-card-model {
    font-size: 13px;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .product-card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--green);
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 1px;
    margin-top: 12px;
    transition: gap var(--transition);
  }

  .product-card:hover .product-card-link { gap: 10px; }

  .product-card-main {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .product-card-mp {
    display: flex;
    gap: 4px;
    padding: 10px 20px 14px;
    border-top: 1px solid var(--border);
  }

  .pmp {
    flex: 1;
    text-align: center;
    padding: 5px 4px;
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 800;
    font-size: 8px;
    text-decoration: none;
    letter-spacing: 0.2px;
    border: 1px solid var(--border);
    transition: all 0.2s ease;
  }

  .pmp-hb { color: #FF6000; }
  .pmp-hb:hover { background: #FF6000; color: #FFF; border-color: #FF6000; }
  .pmp-ty { color: #F27A1A; }
  .pmp-ty:hover { background: #F27A1A; color: #FFF; border-color: #F27A1A; }
  .pmp-az { color: #232F3E; }
  .pmp-az:hover { background: #FF9900; color: #232F3E; border-color: #FF9900; }

  .products-cta {
    text-align: center;
    margin-top: 56px;
  }

  /* ========== TECHNOLOGY ========== */
  .tech-section {
    padding: 120px 0;
    background: #1A1A1A;
    clip-path: polygon(0 40px, 100% 0, 100% calc(100% - 40px), 0 100%);
    margin-top: -40px;
    position: relative;
    z-index: 1;
  }

  .tech-label {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(107, 224, 63, 0.15);
    color: var(--green);
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 2px;
    margin-bottom: 16px;
    border-left: 3px solid var(--green);
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 56px;
  }

  .tech-card {
    background: #2D2D2D;
    padding: 40px 32px;
    transition: all var(--transition);
    border-bottom: 3px solid transparent;
  }

  .tech-card:hover {
    border-bottom-color: var(--green);
    transform: translateY(-4px);
  }

  .tech-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(107, 224, 63, 0.1);
    margin-bottom: 24px;
  }

  .tech-card h3 {
    font-family: 'GeneralSans-Bold', sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: var(--white);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .tech-card p {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255,255,255,0.5);
  }

